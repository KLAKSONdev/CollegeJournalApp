<Window x:Class="CollegeJournalApp.Views.AuditDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подробности действия"
        Height="480" Width="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        Background="#FAF9F8">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок с иконкой действия -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" x:Name="BdrIcon"
                        Width="40" Height="40" CornerRadius="20"
                        Background="#0078D4" Margin="0,0,14,0">
                    <TextBlock x:Name="TxtIcon" Text="●"
                               Foreground="White" FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtActionRu" FontSize="15"
                               FontWeight="SemiBold" Foreground="#1F1F1F"/>
                    <TextBlock x:Name="TxtDateTime" FontSize="11"
                               Foreground="#605E5C" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Содержимое -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20,16,20,0">
            <StackPanel>

                <!-- Карточка пользователя -->
                <Border Background="White" BorderBrush="#E0E0E0"
                        BorderThickness="1" Padding="16,14" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="36" Height="36"
                                CornerRadius="18" Background="#EFF6FC"
                                Margin="0,0,14,0">
                            <TextBlock x:Name="TxtAvatar" FontSize="14"
                                       FontWeight="SemiBold" Foreground="#0078D4"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtUserFullName"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#1F1F1F"/>
                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                <Border x:Name="BdrRole" Background="#EFF6FC"
                                        Padding="7,2" Margin="0,0,8,0">
                                    <TextBlock x:Name="TxtRole" FontSize="10"
                                               Foreground="#0078D4"/>
                                </Border>
                                <TextBlock x:Name="TxtLogin" FontSize="11"
                                           Foreground="#605E5C"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Детали действия -->
                <Border Background="White" BorderBrush="#E0E0E0"
                        BorderThickness="1" Padding="16,14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="ДЕТАЛИ ДЕЙСТВИЯ" FontSize="9"
                                   FontWeight="SemiBold" Foreground="#605E5C"
                                   Margin="0,0,0,12"/>
                        <Grid x:Name="GridDetails">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Раздел системы"
                                       FontSize="11" Foreground="#A19F9D" Margin="0,0,0,10"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtTable"
                                       FontSize="11" Foreground="#1F1F1F" Margin="0,0,0,10"
                                       TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Запись"
                                       FontSize="11" Foreground="#A19F9D" Margin="0,0,0,10"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtRecord"
                                       FontSize="11" Foreground="#1F1F1F" Margin="0,0,0,10"
                                       TextWrapping="Wrap"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="IP-адрес"
                                       FontSize="11" Foreground="#A19F9D" Margin="0,0,0,10"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtIP"
                                       FontSize="11" Foreground="#1F1F1F" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" x:Name="LblView"
                                       Text="Просмотрено" Visibility="Collapsed"
                                       FontSize="11" Foreground="#A19F9D" Margin="0,0,0,10"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TxtView"
                                       Visibility="Collapsed"
                                       FontSize="11" Foreground="#1F1F1F" Margin="0,0,0,10"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Блок изменений (только если есть OldValues/NewValues) -->
                <Border x:Name="BdrChanges" Background="White" BorderBrush="#E0E0E0"
                        BorderThickness="1" Padding="16,14" Margin="0,0,0,12"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="ИЗМЕНЕНИЯ" FontSize="9"
                                   FontWeight="SemiBold" Foreground="#605E5C"
                                   Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Было" FontSize="10"
                                           Foreground="#A19F9D" Margin="0,0,0,6"/>
                                <Border Background="#FFF4CE" Padding="10,8">
                                    <TextBlock x:Name="TxtOld" FontSize="11"
                                               Foreground="#7A4F00" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Стало" FontSize="10"
                                           Foreground="#A19F9D" Margin="0,0,0,6"/>
                                <Border Background="#DFF6DD" Padding="10,8">
                                    <TextBlock x:Name="TxtNew" FontSize="11"
                                               Foreground="#0B5A0B" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Кнопка закрыть -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0" Padding="20,10">
            <Button Content="Закрыть" HorizontalAlignment="Right"
                    Width="90" Height="32"
                    Background="#F3F2F1" Foreground="#323130"
                    BorderBrush="#D0D0D0" BorderThickness="1"
                    FontFamily="Segoe UI" FontSize="12" Cursor="Hand"
                    Click="BtnClose_Click"/>
        </Border>
    </Grid>
</Window>
