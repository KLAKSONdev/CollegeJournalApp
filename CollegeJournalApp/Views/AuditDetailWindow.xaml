<Window x:Class="CollegeJournalApp.Views.AuditDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подробности действия"
        Height="560" Width="640"
        MinHeight="520" MinWidth="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI"
        Background="#F4F6FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ Заголовок ══ -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="#E3E6EE" BorderThickness="0,0,0,1"
                Padding="22,16,22,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Иконка действия -->
                <Border Grid.Column="0" x:Name="BdrIcon"
                        Width="44" Height="44" CornerRadius="10"
                        Background="#0078D4" Margin="0,0,16,0">
                    <Border.Effect>
                        <DropShadowEffect Color="#0078D4" BlurRadius="10"
                                          ShadowDepth="2" Opacity="0.35" Direction="270"/>
                    </Border.Effect>
                    <TextBlock x:Name="TxtIcon" Text="●"
                               Foreground="White" FontSize="18"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtActionRu"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="#1B2A4A"/>
                    <TextBlock x:Name="TxtDateTime"
                               FontSize="11.5" Foreground="#8A94A6"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Контент ══ -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="20,16,20,4">
            <StackPanel>

                <!-- ─ Карточка пользователя ─ -->
                <Border Background="White" CornerRadius="10"
                        BorderBrush="#E3E6EE" BorderThickness="1"
                        Padding="18,16" Margin="0,0,0,12">
                    <Border.Effect>
                        <DropShadowEffect Color="#C0CADE" BlurRadius="8"
                                          ShadowDepth="1" Opacity="0.14" Direction="270"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Аватар -->
                        <Border Grid.Column="0" Width="42" Height="42"
                                CornerRadius="21" Background="#EFF6FC"
                                Margin="0,0,16,0">
                            <TextBlock x:Name="TxtAvatar" FontSize="16"
                                       FontWeight="Bold" Foreground="#0078D4"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtUserFullName"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="#1B2A4A"/>
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <Border x:Name="BdrRole" Background="#EFF6FC"
                                        CornerRadius="4" Padding="8,2" Margin="0,0,10,0">
                                    <TextBlock x:Name="TxtRole" FontSize="10.5"
                                               FontWeight="SemiBold" Foreground="#0063B1"/>
                                </Border>
                                <TextBlock x:Name="TxtLogin" FontSize="11.5"
                                           Foreground="#8A94A6"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ─ Детали действия ─ -->
                <Border Background="White" CornerRadius="10"
                        BorderBrush="#E3E6EE" BorderThickness="1"
                        Padding="18,16" Margin="0,0,0,12">
                    <Border.Effect>
                        <DropShadowEffect Color="#C0CADE" BlurRadius="8"
                                          ShadowDepth="1" Opacity="0.14" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="ДЕТАЛИ ДЕЙСТВИЯ"
                                   FontSize="9.5" FontWeight="Bold"
                                   Foreground="#8A94A6"
                                   Margin="0,0,0,14"/>

                        <!-- Строки деталей -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Раздел системы -->
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Раздел системы"
                                       FontSize="11.5" Foreground="#8A94A6"
                                       Margin="0,0,0,11" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       x:Name="TxtTable"
                                       FontSize="11.5" Foreground="#1B2A4A"
                                       Margin="0,0,0,11" TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>

                            <!-- Запись -->
                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="Запись"
                                       FontSize="11.5" Foreground="#8A94A6"
                                       Margin="0,0,0,11" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       x:Name="TxtRecord"
                                       FontSize="11.5" Foreground="#1B2A4A"
                                       Margin="0,0,0,11" TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>

                            <!-- IP-адрес -->
                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="IP-адрес"
                                       FontSize="11.5" Foreground="#8A94A6"
                                       Margin="0,0,0,11" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       x:Name="TxtIP"
                                       FontSize="11.5" Foreground="#1B2A4A"
                                       FontFamily="Consolas"
                                       Margin="0,0,0,11" VerticalAlignment="Center"/>

                            <!-- Просмотрено (скрыто по умолчанию) -->
                            <TextBlock Grid.Row="3" Grid.Column="0"
                                       x:Name="LblView" Text="Просмотрено"
                                       Visibility="Collapsed"
                                       FontSize="11.5" Foreground="#8A94A6"
                                       Margin="0,0,0,4" VerticalAlignment="Top"/>
                            <TextBlock Grid.Row="3" Grid.Column="1"
                                       x:Name="TxtView"
                                       Visibility="Collapsed"
                                       FontSize="11.5" Foreground="#1B2A4A"
                                       Margin="0,0,0,4" TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ─ Блок изменений ─ -->
                <Border x:Name="BdrChanges" Visibility="Collapsed"
                        Background="White" CornerRadius="10"
                        BorderBrush="#E3E6EE" BorderThickness="1"
                        Padding="18,16" Margin="0,0,0,12">
                    <Border.Effect>
                        <DropShadowEffect Color="#C0CADE" BlurRadius="8"
                                          ShadowDepth="1" Opacity="0.14" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="ИЗМЕНЕНИЯ В ЗАПИСИ"
                                   FontSize="9.5" FontWeight="Bold"
                                   Foreground="#8A94A6"
                                   Margin="0,0,0,14"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Было -->
                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Width="6" Height="6" CornerRadius="3"
                                            Background="#CA5010" Margin="0,0,6,0"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Text="Было" FontSize="11"
                                               FontWeight="SemiBold" Foreground="#7A4F00"/>
                                </StackPanel>
                                <Border Background="#FFF8EC" CornerRadius="7"
                                        BorderBrush="#F3D492" BorderThickness="1"
                                        Padding="12,10" MinHeight="48">
                                    <TextBlock x:Name="TxtOld" FontSize="11.5"
                                               Foreground="#5A3700" TextWrapping="Wrap"
                                               LineHeight="18"/>
                                </Border>
                            </StackPanel>

                            <!-- Стрелка -->
                            <TextBlock Grid.Column="1" Text="→"
                                       FontSize="18" Foreground="#C8D0DF"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,16,0,0"/>

                            <!-- Стало -->
                            <StackPanel Grid.Column="2">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Width="6" Height="6" CornerRadius="3"
                                            Background="#107C10" Margin="0,0,6,0"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Text="Стало" FontSize="11"
                                               FontWeight="SemiBold" Foreground="#0B5A0B"/>
                                </StackPanel>
                                <Border Background="#F0FBF0" CornerRadius="7"
                                        BorderBrush="#9FCEA9" BorderThickness="1"
                                        Padding="12,10" MinHeight="48">
                                    <TextBlock x:Name="TxtNew" FontSize="11.5"
                                               Foreground="#0B3A0B" TextWrapping="Wrap"
                                               LineHeight="18"/>
                                </Border>
                            </StackPanel>

                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ══ Нижняя панель ══ -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="#E3E6EE" BorderThickness="0,1,0,0"
                Padding="22,12">
            <Button Content="Закрыть" HorizontalAlignment="Right"
                    Width="100" Height="34"
                    Foreground="White"
                    BorderThickness="0"
                    FontFamily="Segoe UI" FontSize="12.5"
                    Cursor="Hand"
                    Click="BtnClose_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bdr" Background="#0078D4"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bdr" Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bdr" Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Border>

    </Grid>
</Window>
