<Window x:Class="CollegeJournalApp.Views.Dialogs.PersonalEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Паспортные и личные данные"
        Height="560" Width="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        Background="#FAF9F8"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#605E5C"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        <Style x:Key="Inp" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Cmb" TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1" Padding="20,14">
            <TextBlock Text="Редактировать личные данные"
                       FontSize="15" FontWeight="SemiBold" Foreground="#1F1F1F"/>
        </Border>

        <!-- Форма -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16,20,0">
            <StackPanel>

                <TextBlock Text="ДОПОЛНИТЕЛЬНЫЕ СВЕДЕНИЯ" FontSize="10" FontWeight="SemiBold"
                           Foreground="#0078D4" Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Место рождения" Style="{StaticResource Lbl}"/>
                        <TextBox x:Name="TxtBirthPlace" Style="{StaticResource Inp}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Гражданство" Style="{StaticResource Lbl}"/>
                        <TextBox x:Name="TxtCitizenship" Style="{StaticResource Inp}"/>
                    </StackPanel>
                </Grid>

                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="Адрес проживания" Style="{StaticResource Lbl}"/>
                    <TextBox x:Name="TxtAddress" Style="{StaticResource Inp}"/>
                </StackPanel>

                <Rectangle Height="1" Fill="#E0E0E0" Margin="0,0,0,14"/>
                <TextBlock Text="ПАСПОРТНЫЕ ДАННЫЕ" FontSize="10" FontWeight="SemiBold"
                           Foreground="#0078D4" Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Серия (4 цифры)" Style="{StaticResource Lbl}"/>
                        <TextBox x:Name="TxtPassportSeries" Style="{StaticResource Inp}" MaxLength="4"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Номер (6 цифр)" Style="{StaticResource Lbl}"/>
                        <TextBox x:Name="TxtPassportNumber" Style="{StaticResource Inp}" MaxLength="6"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Дата выдачи" Style="{StaticResource Lbl}"/>
                        <DatePicker x:Name="DpPassportDate" Height="30" FontSize="12"/>
                    </StackPanel>
                </Grid>

                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Кем выдан" Style="{StaticResource Lbl}"/>
                    <TextBox x:Name="TxtPassportIssuedBy" Style="{StaticResource Inp}"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="СНИЛС (формат: 123-456-789 00)" Style="{StaticResource Lbl}"/>
                    <TextBox x:Name="TxtSnils" Style="{StaticResource Inp}" MaxLength="14"/>
                </StackPanel>

                <Rectangle Height="1" Fill="#E0E0E0" Margin="0,0,0,14"/>
                <TextBlock Text="ПРЕДЫДУЩЕЕ ОБРАЗОВАНИЕ" FontSize="10" FontWeight="SemiBold"
                           Foreground="#0078D4" Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Учебное заведение" Style="{StaticResource Lbl}"/>
                        <TextBox x:Name="TxtPrevSchool" Style="{StaticResource Inp}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Тип" Style="{StaticResource Lbl}"/>
                        <ComboBox x:Name="CmbPrevSchoolType" Style="{StaticResource Cmb}">
                            <ComboBoxItem Content="— не указано —" Tag=""/>
                            <ComboBoxItem Content="Школа"     Tag="Школа"/>
                            <ComboBoxItem Content="Гимназия"  Tag="Гимназия"/>
                            <ComboBoxItem Content="Лицей"     Tag="Лицей"/>
                            <ComboBoxItem Content="Колледж"   Tag="Колледж"/>
                            <ComboBoxItem Content="Техникум"  Tag="Техникум"/>
                            <ComboBoxItem Content="Другое"    Tag="Другое"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0" Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Click="BtnCancel_Click"
                        Width="90" Height="32" Margin="0,0,8,0"
                        Background="White" Foreground="#323130"
                        BorderBrush="#D0D0D0" BorderThickness="1"
                        FontFamily="Segoe UI" FontSize="12" Cursor="Hand"/>
                <Button Content="Сохранить" Click="BtnSave_Click"
                        Width="100" Height="32"
                        Background="#0078D4" Foreground="White"
                        BorderThickness="0"
                        FontFamily="Segoe UI" FontSize="12" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
