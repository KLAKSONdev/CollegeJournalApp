<Window x:Class="CollegeJournalApp.Views.Dialogs.AchievementEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Достижение"
        Height="480" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        Background="#F4F6FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="#E3E6EE" BorderThickness="0,0,0,1"
                Padding="22,16">
            <StackPanel Orientation="Horizontal">
                <Border Width="36" Height="36" CornerRadius="8"
                        Background="#FFF4CE" Margin="0,0,12,0">
                    <TextBlock Text="🏆" FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TxtWindowTitle"
                               Text="Новое достижение"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="#1B2A4A"/>
                    <TextBlock x:Name="TxtStudentName"
                               FontSize="11" Foreground="#8A94A6"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Форма -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Padding="22,16,22,4">
            <StackPanel>

                <!-- Название -->
                <TextBlock Text="Название *" FontSize="11" FontWeight="SemiBold"
                           Foreground="#5A667A" Margin="0,0,0,5"/>
                <Border BorderBrush="#D0D8E8" BorderThickness="1" CornerRadius="6"
                        Background="White" Margin="0,0,0,14">
                    <TextBox x:Name="TxtTitle" BorderThickness="0"
                             Padding="10,8" FontSize="13"
                             Background="Transparent"/>
                </Border>

                <!-- Категория + Уровень в одну строку -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Категория" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#5A667A" Margin="0,0,0,5"/>
                        <Border BorderBrush="#D0D8E8" BorderThickness="1" CornerRadius="6"
                                Background="White">
                            <ComboBox x:Name="CmbCategory" BorderThickness="0"
                                      Background="Transparent" Padding="8,6"
                                      FontSize="12">
                                <ComboBoxItem Content="Олимпиады"/>
                                <ComboBoxItem Content="Наука"/>
                                <ComboBoxItem Content="Спорт"/>
                                <ComboBoxItem Content="Творчество"/>
                                <ComboBoxItem Content="Общественная деятельность"/>
                                <ComboBoxItem Content="Другое" IsSelected="True"/>
                            </ComboBox>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Уровень" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#5A667A" Margin="0,0,0,5"/>
                        <Border BorderBrush="#D0D8E8" BorderThickness="1" CornerRadius="6"
                                Background="White">
                            <ComboBox x:Name="CmbLevel" BorderThickness="0"
                                      Background="Transparent" Padding="8,6"
                                      FontSize="12">
                                <ComboBoxItem Content="Колледж" IsSelected="True"/>
                                <ComboBoxItem Content="Городской"/>
                                <ComboBoxItem Content="Региональный"/>
                                <ComboBoxItem Content="Федеральный"/>
                                <ComboBoxItem Content="Международный"/>
                            </ComboBox>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Дата + Номер документа -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Дата" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#5A667A" Margin="0,0,0,5"/>
                        <Border BorderBrush="#D0D8E8" BorderThickness="1" CornerRadius="6"
                                Background="White">
                            <DatePicker x:Name="DtAchieve" BorderThickness="0"
                                        Background="Transparent" Padding="6,4"
                                        FontSize="12"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="№ документа / диплома"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="#5A667A" Margin="0,0,0,5"/>
                        <Border BorderBrush="#D0D8E8" BorderThickness="1" CornerRadius="6"
                                Background="White">
                            <TextBox x:Name="TxtDocNumber" BorderThickness="0"
                                     Padding="10,8" FontSize="12"
                                     Background="Transparent"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Описание -->
                <TextBlock Text="Описание" FontSize="11" FontWeight="SemiBold"
                           Foreground="#5A667A" Margin="0,0,0,5"/>
                <Border BorderBrush="#D0D8E8" BorderThickness="1" CornerRadius="6"
                        Background="White" Margin="0,0,0,4">
                    <TextBox x:Name="TxtDescription" BorderThickness="0"
                             Padding="10,8" FontSize="12"
                             Background="Transparent"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             Height="80" VerticalScrollBarVisibility="Auto"/>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="#E3E6EE" BorderThickness="0,1,0,0"
                Padding="22,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Click="BtnCancel_Click"
                        Width="90" Height="34" Margin="0,0,10,0"
                        Background="#F0F4FB" Foreground="#3D4A60"
                        FontSize="12" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bdr" Background="#F0F4FB"
                                    CornerRadius="7" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bdr" Property="Background" Value="#E0EAF8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="💾  Сохранить" Click="BtnSave_Click"
                        Width="120" Height="34"
                        FontSize="12" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bdr" Background="#0078D4"
                                    CornerRadius="7" Padding="{TemplateBinding Padding}">
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="White" FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bdr" Property="Background" Value="#106EBE"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bdr" Property="Background" Value="#005A9E"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

    </Grid>
</Window>
