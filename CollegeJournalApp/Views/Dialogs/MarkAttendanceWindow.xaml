<Window x:Class="CollegeJournalApp.Views.Dialogs.MarkAttendanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отметка посещаемости"
        Width="640" Height="720" MinWidth="560" MinHeight="520"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI" Background="#FAF9F8"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Синяя шапка -->
            <RowDefinition Height="Auto"/>  <!-- Панель выбора занятия -->
            <RowDefinition Height="Auto"/>  <!-- Информационная полоса -->
            <RowDefinition Height="*"/>     <!-- Список студентов -->
            <RowDefinition Height="Auto"/>  <!-- Подвал -->
        </Grid.RowDefinitions>

        <!-- ═══ Шапка ═══════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#0078D4" Padding="20,14">
            <StackPanel>
                <TextBlock Text="Отметка посещаемости" FontSize="16"
                           FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Text="Выберите дату и занятие, затем отметьте каждого студента"
                           FontSize="11" Foreground="#C8E4FF" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- ═══ Панель выбора занятия ════════════════════════════ -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Дата -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Дата занятия" FontSize="10" Foreground="#605E5C" Margin="0,0,0,4"/>
                    <DatePicker x:Name="DtPicker" Width="150" Height="30"
                                SelectedDateChanged="DtPicker_Changed"
                                FontSize="12"/>
                </StackPanel>

                <!-- Занятие -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Занятие" FontSize="10" Foreground="#605E5C" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CmbLesson" Height="30" FontSize="12"
                              SelectionChanged="CmbLesson_Changed"
                              DisplayMemberPath="DisplayName"/>
                </StackPanel>

                <!-- Кнопка обновления -->
                <Button Grid.Column="3" x:Name="BtnRefresh"
                        Content="↻ Обновить" Height="30" Width="100"
                        Margin="8,18,0,0" Padding="10,0"
                        Background="Transparent" BorderBrush="#D0D0D0" BorderThickness="1"
                        FontSize="12" Cursor="Hand" Click="BtnRefresh_Click"/>
            </Grid>
        </Border>

        <!-- ═══ Информационная полоса ════════════════════════════ -->
        <Border x:Name="InfoStrip" Grid.Row="2"
                Background="#EFF6FC" BorderBrush="#C7E0F4" BorderThickness="0,0,0,1"
                Padding="20,8" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock x:Name="TxtInfoSubject"
                               FontSize="12" FontWeight="SemiBold" Foreground="#0078D4"/>
                    <TextBlock x:Name="TxtInfoGroup"
                               FontSize="12" Foreground="#605E5C" Margin="8,0,0,0"/>
                </StackPanel>
                <TextBlock x:Name="TxtInfoCount" Grid.Column="1"
                           FontSize="12" Foreground="#605E5C"/>
            </Grid>
        </Border>

        <!-- ═══ Список студентов ════════════════════════════════ -->
        <Border Grid.Row="3" Margin="0" Background="White">
            <Grid>
                <!-- Пустое состояние -->
                <StackPanel x:Name="EmptyState" VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center"
                               Opacity="0.3" Margin="0,0,0,8"/>
                    <TextBlock x:Name="TxtEmpty"
                               Text="Выберите дату и занятие для загрузки списка студентов"
                               FontSize="13" Foreground="#A19F9D" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" MaxWidth="300"/>
                </StackPanel>

                <!-- Список -->
                <ScrollViewer x:Name="Scroll" VerticalScrollBarVisibility="Auto"
                              Visibility="Collapsed">
                    <StackPanel x:Name="StudentsPanel" Background="White"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ═══ Подвал ══════════════════════════════════════════ -->
        <Border Grid.Row="4" Background="White" BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="BtnMarkAll"
                        Content="✓ Всех присутствующими" Height="32" Padding="14,0"
                        HorizontalAlignment="Left"
                        Background="Transparent" BorderBrush="#107C10" BorderThickness="1"
                        FontSize="12" Foreground="#107C10" Cursor="Hand"
                        Click="BtnMarkAll_Click" IsEnabled="False"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Отмена" Height="32" Padding="16,0" Margin="0,0,8,0"
                            Background="Transparent" BorderBrush="#D0D0D0" BorderThickness="1"
                            FontSize="12" Foreground="#605E5C" Cursor="Hand"
                            Click="BtnCancel_Click"/>
                    <Button x:Name="BtnSave"
                            Content="💾 Сохранить" Height="32" Padding="16,0"
                            Background="#0078D4" Foreground="White" BorderThickness="0"
                            FontSize="12" Cursor="Hand" FontWeight="SemiBold"
                            Click="BtnSave_Click" IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
