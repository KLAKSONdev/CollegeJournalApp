<Window x:Class="CollegeJournalApp.Views.Dialogs.DocUploadDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Загрузка документа"
        Height="340" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        Background="#F4F6FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="#E3E6EE" BorderThickness="0,0,0,1"
                Padding="22,14">
            <StackPanel Orientation="Horizontal">
                <Border Width="34" Height="34" CornerRadius="8"
                        Background="#EFF6FC" Margin="0,0,12,0">
                    <TextBlock Text="📄" FontSize="15"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Сведения о документе"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#1B2A4A"/>
                    <TextBlock x:Name="TxtFileName" FontSize="11"
                               Foreground="#8A94A6" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Форма -->
        <StackPanel Grid.Row="1" Margin="22,16,22,8">

            <TextBlock Text="Название *" FontSize="11" FontWeight="SemiBold"
                       Foreground="#5A667A" Margin="0,0,0,5"/>
            <Border BorderBrush="#D0D8E8" BorderThickness="1" CornerRadius="6"
                    Background="White" Margin="0,0,0,14">
                <TextBox x:Name="TxtTitle" BorderThickness="0"
                         Padding="10,8" FontSize="13" Background="Transparent"/>
            </Border>

            <TextBlock Text="Тип документа" FontSize="11" FontWeight="SemiBold"
                       Foreground="#5A667A" Margin="0,0,0,5"/>
            <Border BorderBrush="#D0D8E8" BorderThickness="1" CornerRadius="6"
                    Background="White" Margin="0,0,0,14">
                <ComboBox x:Name="CmbDocType" BorderThickness="0"
                          Background="Transparent" Padding="8,6" FontSize="12">
                    <ComboBoxItem Content="Паспорт"/>
                    <ComboBoxItem Content="СНИЛС"/>
                    <ComboBoxItem Content="Диплом / Аттестат"/>
                    <ComboBoxItem Content="Справка"/>
                    <ComboBoxItem Content="Медицинский документ"/>
                    <ComboBoxItem Content="Договор"/>
                    <ComboBoxItem Content="Приказ"/>
                    <ComboBoxItem Content="Прочее" IsSelected="True"/>
                </ComboBox>
            </Border>

            <TextBlock Text="Описание" FontSize="11" FontWeight="SemiBold"
                       Foreground="#5A667A" Margin="0,0,0,5"/>
            <Border BorderBrush="#D0D8E8" BorderThickness="1" CornerRadius="6"
                    Background="White">
                <TextBox x:Name="TxtDescription" BorderThickness="0"
                         Padding="10,8" FontSize="12" Background="Transparent"
                         TextWrapping="Wrap" AcceptsReturn="True" Height="52"
                         VerticalScrollBarVisibility="Auto"/>
            </Border>
        </StackPanel>

        <!-- Кнопки -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="#E3E6EE" BorderThickness="0,1,0,0"
                Padding="22,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Click="BtnCancel_Click"
                        Width="90" Height="34" Margin="0,0,10,0"
                        FontSize="12" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bdr" Background="#F0F4FB"
                                    CornerRadius="7" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bdr" Property="Background" Value="#E0EAF8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="⬆  Загрузить" Click="BtnOk_Click"
                        Width="120" Height="34" FontSize="12" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bdr" Background="#0078D4"
                                    CornerRadius="7" Padding="{TemplateBinding Padding}">
                                <TextBlock Text="{TemplateBinding Content}"
                                           Foreground="White" FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bdr" Property="Background" Value="#106EBE"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
