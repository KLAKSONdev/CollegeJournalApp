<Window x:Class="CollegeJournalApp.Views.Dialogs.DocumentAddDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить документ"
        Height="420" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        Background="#FAF9F8"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#605E5C"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        <Style x:Key="Inp" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Cmb" TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1" Padding="20,14">
            <TextBlock Text="Добавить документ"
                       FontSize="15" FontWeight="SemiBold" Foreground="#1F1F1F"/>
        </Border>

        <!-- Форма -->
        <StackPanel Grid.Row="1" Margin="20,16,20,0">

            <StackPanel Margin="0,0,0,12">
                <TextBlock Text="Название *" Style="{StaticResource Lbl}"/>
                <TextBox x:Name="TxtTitle" Style="{StaticResource Inp}"/>
            </StackPanel>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Тип документа" Style="{StaticResource Lbl}"/>
                    <ComboBox x:Name="CmbType" Style="{StaticResource Cmb}">
                        <ComboBoxItem Content="— не указан —"  Tag=""/>
                        <ComboBoxItem Content="Приказ"         Tag="Приказ"/>
                        <ComboBoxItem Content="Справка"        Tag="Справка"/>
                        <ComboBoxItem Content="Протокол"       Tag="Протокол"/>
                        <ComboBoxItem Content="Расписание"     Tag="Расписание"/>
                        <ComboBoxItem Content="Ведомость"      Tag="Ведомость"/>
                        <ComboBoxItem Content="Учебный план"   Tag="Учебный план"/>
                        <ComboBoxItem Content="Другое"         Tag="Другое"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Описание" Style="{StaticResource Lbl}"/>
                    <TextBox x:Name="TxtDescription" Style="{StaticResource Inp}"/>
                </StackPanel>
            </Grid>

            <!-- Файл -->
            <TextBlock Text="Файл (необязательно)" Style="{StaticResource Lbl}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtFilePath" Grid.Column="0"
                         Style="{StaticResource Inp}"
                         IsReadOnly="True" Background="#F3F2F1"
                         Foreground="#605E5C"
                         Text="Файл не выбран"/>
                <Button Grid.Column="2" Content="Обзор..."
                        Height="30" Padding="12,0"
                        Background="#F3F2F1" Foreground="#323130"
                        BorderBrush="#D0D0D0" BorderThickness="1"
                        FontFamily="Segoe UI" FontSize="12"
                        Cursor="Hand" Click="BtnBrowse_Click"/>
                <Button x:Name="BtnClearFile" Grid.Column="4" Content="✕"
                        Height="30" Width="30"
                        Background="White" Foreground="#D13438"
                        BorderBrush="#D13438" BorderThickness="1"
                        FontFamily="Segoe UI" FontSize="12"
                        Cursor="Hand" Visibility="Collapsed"
                        Click="BtnClearFile_Click"/>
            </Grid>

            <TextBlock x:Name="TxtFileInfo" Text="" FontSize="10"
                       Foreground="#A19F9D" Margin="0,4,0,0"/>

            <TextBlock Margin="0,16,0,0" TextWrapping="Wrap"
                       FontSize="11" Foreground="#605E5C">
                <Run FontWeight="SemiBold">Примечание:</Run>
                <Run>документ будет доступен всем студентам группы.</Run>
                <Run>Если прикреплён файл — он сохраняется на диске и его можно открыть из карточки.</Run>
            </TextBlock>

        </StackPanel>

        <!-- Кнопки -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0" Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Click="BtnCancel_Click"
                        Width="90" Height="32" Margin="0,0,8,0"
                        Background="White" Foreground="#323130"
                        BorderBrush="#D0D0D0" BorderThickness="1"
                        FontFamily="Segoe UI" FontSize="12" Cursor="Hand"/>
                <Button Content="Добавить" Click="BtnSave_Click"
                        Width="100" Height="32"
                        Background="#0078D4" Foreground="White"
                        BorderThickness="0"
                        FontFamily="Segoe UI" FontSize="12" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
