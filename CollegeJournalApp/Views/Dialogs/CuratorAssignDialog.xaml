<Window x:Class="CollegeJournalApp.Views.Dialogs.CuratorAssignDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Назначить куратора" Height="220" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        FontFamily="Segoe UI" Background="#FAF9F8"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1" Padding="20,14">
            <StackPanel>
                <TextBlock Text="Назначить куратора" FontSize="15"
                           FontWeight="SemiBold" Foreground="#1F1F1F"/>
                <TextBlock x:Name="TxtGroupName" FontSize="11"
                           Foreground="#605E5C" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="20,16,20,0">
            <TextBlock Text="Преподаватель" FontSize="11"
                       Foreground="#605E5C" Margin="0,0,0,5"/>
            <ComboBox x:Name="CmbTeacher" Height="32" FontSize="12"/>
            <TextBlock Text="Выберите «— Снять куратора —» чтобы убрать текущего"
                       FontSize="10" Foreground="#A19F9D" Margin="0,6,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0" Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Click="BtnCancel_Click"
                        Width="90" Height="32" Margin="0,0,8,0"
                        Background="White" Foreground="#323130"
                        BorderBrush="#D0D0D0" BorderThickness="1"
                        FontFamily="Segoe UI" FontSize="12" Cursor="Hand"/>
                <Button Content="Сохранить" Click="BtnSave_Click"
                        Width="100" Height="32"
                        Background="#0078D4" Foreground="White"
                        BorderThickness="0" FontFamily="Segoe UI"
                        FontSize="12" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
