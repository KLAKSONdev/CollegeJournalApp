<Window x:Class="CollegeJournalApp.Views.Dialogs.AcademicYearEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учебный год" Height="320" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        FontFamily="Segoe UI" Background="#FAF9F8"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#605E5C"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        <Style x:Key="Inp" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1" Padding="20,14">
            <TextBlock x:Name="TxtTitle" Text="Учебный год" FontSize="15"
                       FontWeight="SemiBold" Foreground="#1F1F1F"/>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="20,16,20,0">
            <StackPanel>
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Style="{StaticResource Lbl}">
                        Название * <Run Foreground="#A19F9D">(например: 2024-2025)</Run>
                    </TextBlock>
                    <TextBox x:Name="TxtName" Style="{StaticResource Inp}"/>
                </StackPanel>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Дата начала *" Style="{StaticResource Lbl}"/>
                        <DatePicker x:Name="DpStart" Height="30" FontSize="12"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Дата окончания *" Style="{StaticResource Lbl}"/>
                        <DatePicker x:Name="DpEnd" Height="30" FontSize="12"/>
                    </StackPanel>
                </Grid>

                <CheckBox x:Name="ChkCurrent" Content="Текущий учебный год"
                          Margin="0,12,0,4" FontSize="12"
                          Checked="ChkCurrent_Changed" Unchecked="ChkCurrent_Changed"/>
                <TextBlock x:Name="TxtCurrentHint"
                           Text="При сохранении остальные годы будут сброшены"
                           FontSize="10" Foreground="#A19F9D"
                           Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0" Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Click="BtnCancel_Click"
                        Width="90" Height="32" Margin="0,0,8,0"
                        Background="White" Foreground="#323130"
                        BorderBrush="#D0D0D0" BorderThickness="1"
                        FontFamily="Segoe UI" FontSize="12" Cursor="Hand"/>
                <Button Content="Сохранить" Click="BtnSave_Click"
                        Width="100" Height="32"
                        Background="#0078D4" Foreground="White"
                        BorderThickness="0" FontFamily="Segoe UI"
                        FontSize="12" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
