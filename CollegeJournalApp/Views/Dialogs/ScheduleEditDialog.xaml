<Window x:Class="CollegeJournalApp.Views.Dialogs.ScheduleEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="#FAF9F8" FontFamily="Segoe UI"
        Width="440" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"           Value="12"/>
            <Setter Property="Foreground"         Value="#605E5C"/>
            <Setter Property="VerticalAlignment"  Value="Center"/>
            <Setter Property="Margin"             Value="0,0,0,10"/>
        </Style>
    </Window.Resources>
    <Grid Margin="24,20,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock x:Name="TxtTitle" Grid.Row="0"
                   FontSize="16" FontWeight="SemiBold" Foreground="#1F1F1F"
                   Margin="0,0,0,20"/>

        <!-- Поля формы -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Группа -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Группа" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="CmbGroup" Grid.Row="0" Grid.Column="1"
                      Height="32" FontSize="12" Margin="0,0,0,10"
                      SelectionChanged="CmbGroup_Changed"/>

            <!-- День недели -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="День недели" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="CmbDay" Grid.Row="1" Grid.Column="1"
                      Height="32" FontSize="12" Margin="0,0,0,10">
                <ComboBoxItem Content="Понедельник" Tag="1"/>
                <ComboBoxItem Content="Вторник"     Tag="2"/>
                <ComboBoxItem Content="Среда"       Tag="3"/>
                <ComboBoxItem Content="Четверг"     Tag="4"/>
                <ComboBoxItem Content="Пятница"     Tag="5"/>
                <ComboBoxItem Content="Суббота"     Tag="6"/>
            </ComboBox>

            <!-- Номер пары -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Пара" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="CmbLesson" Grid.Row="2" Grid.Column="1"
                      Height="32" FontSize="12" Margin="0,0,0,10">
                <ComboBoxItem Content="1  —  08:30–10:05" Tag="1"/>
                <ComboBoxItem Content="2  —  10:15–11:50" Tag="2"/>
                <ComboBoxItem Content="3  —  12:30–14:05" Tag="3"/>
                <ComboBoxItem Content="4  —  14:15–15:50" Tag="4"/>
                <ComboBoxItem Content="5  —  16:00–17:35" Tag="5"/>
                <ComboBoxItem Content="6  —  17:45–19:20" Tag="6"/>
            </ComboBox>

            <!-- Предмет -->
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Предмет" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="CmbSubject" Grid.Row="3" Grid.Column="1"
                      Height="32" FontSize="12" Margin="0,0,0,10"
                      SelectionChanged="CmbSubject_Changed"/>

            <!-- Преподаватель (авто) -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Преподаватель" Style="{StaticResource FieldLabel}"/>
            <Border Grid.Row="4" Grid.Column="1" Margin="0,0,0,10"
                    Background="#F3F2F1" BorderBrush="#E0E0E0" BorderThickness="1"
                    CornerRadius="4" Padding="8,6">
                <TextBlock x:Name="TxtTeacher" FontSize="12" Foreground="#605E5C"
                           VerticalAlignment="Center" Text="— выберите предмет —"/>
            </Border>

            <!-- Аудитория -->
            <TextBlock Grid.Row="5" Grid.Column="0" Text="Аудитория" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="TxtClassroom" Grid.Row="5" Grid.Column="1"
                     Height="32" FontSize="12" Margin="0,0,0,10"
                     Padding="8,4" BorderBrush="#E0E0E0"/>

            <!-- Тип недели -->
            <TextBlock Grid.Row="6" Grid.Column="0" Text="Тип недели" Style="{StaticResource FieldLabel}"/>
            <ComboBox x:Name="CmbWeekType" Grid.Row="6" Grid.Column="1"
                      Height="32" FontSize="12" Margin="0,0,0,0">
                <ComboBoxItem Content="Обе"       IsSelected="True"/>
                <ComboBoxItem Content="Чётная"/>
                <ComboBoxItem Content="Нечётная"/>
            </ComboBox>
        </Grid>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Отмена" Width="90" Height="32" Margin="0,0,8,0"
                    FontSize="12" Background="#F3F2F1" Foreground="#1F1F1F"
                    BorderThickness="1" BorderBrush="#E0E0E0" Cursor="Hand"
                    Click="BtnCancel_Click"/>
            <Button Content="Сохранить" Width="110" Height="32"
                    FontSize="12" FontWeight="SemiBold"
                    Background="#0078D4" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
