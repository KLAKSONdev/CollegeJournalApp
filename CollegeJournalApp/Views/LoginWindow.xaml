<Window x:Class="CollegeJournalApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Классный журнал — Вход"
        Height="480" Width="760"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFFFFF"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1F1F1F"/>
            <Setter Property="BorderBrush" Value="#ABABAB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#0078D4"/>
                    <Setter Property="BorderThickness" Value="1,1,1,2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PasswordStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1F1F1F"/>
            <Setter Property="BorderBrush" Value="#ABABAB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#0078D4"/>
                    <Setter Property="BorderThickness" Value="1,1,1,2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель — серая -->
        <Border Grid.Column="0" Background="#F3F3F3"
                BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Margin="24,0">
                <!-- Иконка -->
                <Border Width="64" Height="64"
                        Background="#0078D4"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,20">
                    <TextBlock Text="КЖ"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="SemiBold"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Классный журнал"
                           Foreground="#1F1F1F"
                           FontSize="15"
                           FontWeight="SemiBold"
                           FontFamily="Segoe UI"
                           TextAlignment="Center"
                           Margin="0,0,0,6"/>

                <TextBlock Text="Система управления группой колледжа"
                           Foreground="#605E5C"
                           FontSize="11"
                           FontFamily="Segoe UI"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,24"/>

                <Rectangle Height="1" Fill="#E0E0E0" Margin="0,0,0,16"/>

                <TextBlock Text="2024 — 2025"
                           Foreground="#A19F9D"
                           FontSize="11"
                           FontFamily="Segoe UI"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Правая панель — форма -->
        <Border Grid.Column="1" Padding="40,0">
            <StackPanel VerticalAlignment="Center">

                <TextBlock Text="Вход в систему"
                           Foreground="#1F1F1F"
                           FontSize="20"
                           FontWeight="SemiBold"
                           FontFamily="Segoe UI"
                           Margin="0,0,0,4"/>

                <TextBlock Text="Введите учётные данные для доступа"
                           Foreground="#605E5C"
                           FontSize="12"
                           FontFamily="Segoe UI"
                           Margin="0,0,0,28"/>

                <TextBlock Text="Логин"
                           Foreground="#323130"
                           FontSize="12"
                           FontFamily="Segoe UI"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="TxtLogin"
                         Style="{StaticResource InputStyle}"
                         Height="34"
                         Margin="0,0,0,16"
                         KeyDown="Input_KeyDown"/>

                <TextBlock Text="Пароль"
                           Foreground="#323130"
                           FontSize="12"
                           FontFamily="Segoe UI"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5"/>
                <PasswordBox x:Name="PwdPassword"
                             Style="{StaticResource PasswordStyle}"
                             Height="34"
                             Margin="0,0,0,24"
                             KeyDown="Input_KeyDown"/>

                <Button Content="Войти"
                        Style="{StaticResource PrimaryButton}"
                        Height="36"
                        Padding="0,0"
                        Click="BtnLogin_Click"/>

                <TextBlock x:Name="TxtError"
                           Foreground="#A4262C"
                           FontSize="12"
                           FontFamily="Segoe UI"
                           Margin="0,10,0,0"
                           Visibility="Collapsed"
                           TextWrapping="Wrap"/>

                <TextBlock x:Name="TxtDbStatus"
                           Foreground="#A19F9D"
                           FontSize="10"
                           FontFamily="Segoe UI"
                           Margin="0,20,0,0"
                           HorizontalAlignment="Right"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
