<Window x:Class="CollegeJournalApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="EduTrack Pro"
        Height="480" Width="760"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#FFFFFF"
        FontFamily="Segoe UI">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="0"
                      CornerRadius="0"
                      GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>

        <!-- Кнопки управления окном -->
        <Style x:Key="WinBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Width"           Value="40"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="WinCloseBtnStyle" TargetType="Button" BasedOn="{StaticResource WinBtnStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C50F1F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1F1F1F"/>
            <Setter Property="BorderBrush" Value="#ABABAB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#0078D4"/>
                    <Setter Property="BorderThickness" Value="1,1,1,2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PasswordStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1F1F1F"/>
            <Setter Property="BorderBrush" Value="#ABABAB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#0078D4"/>
                    <Setter Property="BorderThickness" Value="1,1,1,2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- КАСТОМНАЯ ШАПКА -->
        <Border Grid.Row="0" Background="#0078D4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="EduTrack Pro"
                           Foreground="White" FontSize="20" FontFamily="Arial Black"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="─" Style="{StaticResource WinBtnStyle}"
                            Click="BtnLoginMinimize_Click" Height="41" FontWeight="Bold"/>
                    <Button Content="✕" Style="{StaticResource WinCloseBtnStyle}"
                            Click="BtnLoginClose_Click" Height="41" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ОСНОВНОЙ КОНТЕНТ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель — серая -->
            <Border Grid.Column="0" Background="#F3F3F3"
                BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Margin="24,0">
                    <!-- Иконка -->
                    <Border Width="205" Height="205"
                HorizontalAlignment="Center"
                Margin="0,0,0,0">
                        <Image Source="/Img/Icon.png"
                   Width="200"
                   Height="200"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Система управления колледжем"
                           Foreground="#605E5C"
                           FontSize="12"
                           FontFamily="Segoe UI"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,15"/>

                    <Rectangle Height="1" Fill="#E0E0E0" Margin="0,0,0,16"/>

                    <TextBlock Text="Прокопьев М.В"
                           Foreground="#A19F9D"
                           FontSize="11"
                           FontFamily="Segoe UI"
                           TextAlignment="Center" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- Правая панель — форма -->
            <Border Grid.Column="1" Padding="40,0">
                <StackPanel VerticalAlignment="Center">

                    <TextBlock Text="Вход в систему"
                           Foreground="#1F1F1F"
                           FontSize="20"
                           FontWeight="SemiBold"
                           FontFamily="Segoe UI"
                           Margin="0,0,0,4"/>

                    <TextBlock Text="Введите учётные данные для входа"
                           Foreground="#605E5C"
                           FontSize="12"
                           FontFamily="Segoe UI"
                           Margin="0,0,0,28"/>

                    <TextBlock Text="Логин"
                           Foreground="#323130"
                           FontSize="12"
                           FontFamily="Segoe UI"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtLogin"
                         Style="{StaticResource InputStyle}"
                         Height="34"
                         Margin="0,0,0,16"
                         KeyDown="Input_KeyDown"/>

                    <TextBlock Text="Пароль"
                           Foreground="#323130"
                           FontSize="12"
                           FontFamily="Segoe UI"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5"/>
                    <PasswordBox x:Name="PwdPassword"
                             Style="{StaticResource PasswordStyle}"
                             Height="34"
                             Margin="0,0,0,24"
                             KeyDown="Input_KeyDown"/>

                    <Button Content="Войти"
                        Style="{StaticResource PrimaryButton}"
                        Height="36"
                        Padding="0,0"
                        Click="BtnLogin_Click" Width="405"/>


                    <TextBlock x:Name="TxtError"
                           Foreground="#A4262C"
                           FontSize="12"
                           FontFamily="Segoe UI"
                           Margin="0,10,0,0"
                           Visibility="Collapsed"
                           TextWrapping="Wrap"/>

                    <TextBlock x:Name="TxtDbStatus"
                           Foreground="#FF009610"
                           FontSize="10"
                           FontFamily="Segoe UI"
                           Margin="0,20,0,0"
                           HorizontalAlignment="Right"/>
                </StackPanel>
            </Border>
        </Grid>
        <!-- основной контент -->
    </Grid>
</Window>
