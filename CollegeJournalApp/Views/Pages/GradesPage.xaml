<Page x:Class="CollegeJournalApp.Views.Pages.GradesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#FAF9F8" FontFamily="Segoe UI" Title="Успеваемость">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1" Padding="24,14">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Успеваемость" FontSize="18" FontWeight="SemiBold" Foreground="#1F1F1F"/>
                <TextBlock x:Name="TxtTotal" Text="" FontSize="12" Foreground="#605E5C"
                           VerticalAlignment="Bottom" Margin="10,0,0,2"/>
            </StackPanel>
        </Border>

        <!-- Статистика -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="24,16,24,0">
            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,8,0">
                <StackPanel Margin="16,12">
                    <TextBlock x:Name="StatAvg" Text="—" FontSize="24" FontWeight="SemiBold" Foreground="#0078D4"/>
                    <TextBlock Text="Средний балл" FontSize="10" Foreground="#605E5C" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,8,0">
                <StackPanel Margin="16,12">
                    <TextBlock x:Name="StatFive" Text="—" FontSize="24" FontWeight="SemiBold" Foreground="#107C10"/>
                    <TextBlock Text="Отличников (5)" FontSize="10" Foreground="#605E5C" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,8,0">
                <StackPanel Margin="16,12">
                    <TextBlock x:Name="StatTwo" Text="—" FontSize="24" FontWeight="SemiBold" Foreground="#D13438"/>
                    <TextBlock Text="Двоечников (2)" FontSize="10" Foreground="#605E5C" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>
            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel Margin="16,12">
                    <TextBlock x:Name="StatCount" Text="—" FontSize="24" FontWeight="SemiBold" Foreground="#323130"/>
                    <TextBlock Text="Всего оценок" FontSize="10" Foreground="#605E5C" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Фильтры -->
        <Border Grid.Row="2" Background="White" Padding="24,10"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,1" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal">
                <Border BorderBrush="#D0D0D0" BorderThickness="1" Width="200" Height="30" Margin="0,0,8,0">
                    <TextBox x:Name="TxtSearch" BorderThickness="0" Padding="8,6" FontSize="12"
                             Background="White" TextChanged="Filter_Changed">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="Поиск по студенту..." Foreground="#A19F9D"
                                                                   FontFamily="Segoe UI" FontSize="12" Margin="8,6,0,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Border>
                <ComboBox x:Name="CmbSubject" Width="200" Height="30" Margin="0,0,8,0"
                          FontSize="12" SelectionChanged="Filter_Changed"/>
                <ComboBox x:Name="CmbGrade" Width="130" Height="30" Margin="0,0,8,0"
                          FontSize="12" SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="Все оценки" IsSelected="True"/>
                    <ComboBoxItem Content="5"/>
                    <ComboBoxItem Content="4"/>
                    <ComboBoxItem Content="3"/>
                    <ComboBoxItem Content="2"/>
                </ComboBox>
                <Button Content="Сбросить" Height="30" Padding="12,0"
                        Background="Transparent" BorderBrush="#D0D0D0" BorderThickness="1"
                        FontFamily="Segoe UI" FontSize="12" Foreground="#605E5C"
                        Cursor="Hand" Click="BtnReset_Click" Margin="0,0,8,0"/>
                <Button Content="📥 Экспорт" Height="30" Padding="12,0"
                        Background="#107C10" Foreground="White" BorderThickness="0"
                        FontFamily="Segoe UI" FontSize="12" Cursor="Hand"
                        Click="BtnExport_Click"/>
            </StackPanel>
        </Border>

        <!-- Таблица -->
        <Border Grid.Row="3" Margin="24,12,24,16"
                Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
            <DataGrid x:Name="GradesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F3F2F1"
                      BorderThickness="0" Background="White" RowBackground="White"
                      AlternatingRowBackground="#FAFAFA" HeadersVisibility="Column"
                      CanUserResizeRows="False" FontFamily="Segoe UI" FontSize="12" RowHeight="34">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F3F2F1"/>
                        <Setter Property="Foreground" Value="#605E5C"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="BorderBrush" Value="#E0E0E0"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="12,0"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#EFF6FC"/>
                                <Setter Property="Foreground" Value="#1F1F1F"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Студент"    Binding="{Binding StudentName}" Width="220"/>
                    <DataGridTextColumn Header="Дисциплина" Binding="{Binding Subject}"     Width="*"/>
                    <DataGridTextColumn Header="Тип"        Binding="{Binding GradeType}"   Width="130"/>
                    <DataGridTemplateColumn Header="Оценка" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding GradeColor}" Width="32" Height="26"
                                        Margin="8,4" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding GradeValue}" Foreground="White"
                                               FontWeight="SemiBold" FontSize="13"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Дата"       Binding="{Binding GradeDate}"   Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
