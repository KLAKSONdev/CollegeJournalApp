<Page x:Class="CollegeJournalApp.Views.Pages.AuditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F4F6FA"
      FontFamily="Segoe UI"
      Title="Журнал аудита">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ Заголовок ══ -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="#E3E6EE" BorderThickness="0,0,0,1"
                Padding="24,16,24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Иконка + заголовок -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36" Height="36" CornerRadius="8"
                            Background="#EFF6FC" Margin="0,0,12,0">
                        <TextBlock Text="📋" FontSize="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Журнал действий в системе"
                                   FontSize="17" FontWeight="SemiBold"
                                   Foreground="#1B2A4A"/>
                        <TextBlock x:Name="TxtTotal" Text="загрузка…"
                                   FontSize="11" Foreground="#8A94A6"
                                   Margin="0,1,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Подсказка -->
                <TextBlock Grid.Column="2"
                           Text="Двойной клик по строке — открыть подробности"
                           FontSize="11" Foreground="#A8B0C0"
                           VerticalAlignment="Center" FontStyle="Italic"/>
            </Grid>
        </Border>

        <!-- ══ Панель фильтров ══ -->
        <Border Grid.Row="1" Background="White"
                BorderBrush="#E3E6EE" BorderThickness="0,0,0,1"
                Padding="24,10,24,10">
            <StackPanel Orientation="Horizontal">

                <!-- Поиск с иконкой -->
                <Border BorderBrush="#D0D8E8" BorderThickness="1"
                        CornerRadius="6" Background="White"
                        Width="240" Height="32" Margin="0,0,10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍"
                                   FontSize="12" Foreground="#8A94A6"
                                   VerticalAlignment="Center" Margin="10,0,6,0"/>
                        <TextBox x:Name="TxtSearch" Grid.Column="1"
                                 BorderThickness="0" Padding="0,6,8,6"
                                 FontSize="12" Background="Transparent"
                                 VerticalAlignment="Center"
                                 TextChanged="Filter_Changed">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <VisualBrush Stretch="None" AlignmentX="Left">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="Поиск по пользователю…"
                                                                       Foreground="#B0B8C8" FontSize="12"
                                                                       FontFamily="Segoe UI"
                                                                       Margin="0,6,0,0"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>
                </Border>

                <!-- Фильтр действий -->
                <Border BorderBrush="#D0D8E8" BorderThickness="1"
                        CornerRadius="6" Height="32" Margin="0,0,10,0">
                    <ComboBox x:Name="CmbAction" Width="170"
                              BorderThickness="0" Background="Transparent"
                              FontSize="12" Padding="8,0"
                              VerticalContentAlignment="Center"
                              SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="Все действия" IsSelected="True"/>
                        <ComboBoxItem Content="Вход в систему"/>
                        <ComboBoxItem Content="Добавление записи"/>
                        <ComboBoxItem Content="Изменение записи"/>
                        <ComboBoxItem Content="Удаление записи"/>
                        <ComboBoxItem Content="Просмотр данных"/>
                        <ComboBoxItem Content="Отказано в доступе"/>
                    </ComboBox>
                </Border>

                <!-- Кнопка Обновить -->
                <Button Content="⟳  Обновить" Click="BtnRefresh_Click"
                        Height="32" Padding="14,0"
                        Background="#0078D4" Foreground="White"
                        BorderThickness="0"
                        FontFamily="Segoe UI" FontSize="12" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bdr" Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bdr" Property="Background" Value="#106EBE"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bdr" Property="Background" Value="#005A9E"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Кнопка Экспорт -->
                <Button Content="📥  Экспорт" Click="BtnExport_Click"
                        Height="32" Padding="14,0" Margin="8,0,0,0"
                        Background="#107C10" Foreground="White"
                        BorderThickness="0"
                        FontFamily="Segoe UI" FontSize="12" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BdrEx" Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BdrEx" Property="Background" Value="#0B5E0B"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="BdrEx" Property="Background" Value="#094509"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </StackPanel>
        </Border>

        <!-- ══ Таблица ══ -->
        <Border Grid.Row="2" Margin="20,16,20,16"
                Background="White" CornerRadius="10"
                BorderBrush="#E3E6EE" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#C0CADE" BlurRadius="12"
                                  ShadowDepth="2" Opacity="0.18" Direction="270"/>
            </Border.Effect>

            <DataGrid x:Name="AuditGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#EEF1F7"
                      BorderThickness="0"
                      Background="White"
                      RowBackground="White"
                      AlternatingRowBackground="#F8FAFF"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      CanUserResizeRows="False"
                      FontFamily="Segoe UI" FontSize="12"
                      RowHeight="36"
                      MouseDoubleClick="AuditGrid_DoubleClick">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F0F4FB"/>
                        <Setter Property="Foreground" Value="#5A667A"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="14,9"/>
                        <Setter Property="BorderBrush" Value="#E3E6EE"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="14,0"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#EAF3FB"/>
                                <Setter Property="Foreground" Value="#1B2A4A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F5F8FF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>

                    <!-- Дата -->
                    <DataGridTextColumn Header="Дата и время"
                                        Binding="{Binding ActionAt}"
                                        Width="138">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#5A667A"/>
                                <Setter Property="FontSize" Value="11.5"/>
                                <Setter Property="Margin" Value="14,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Пользователь -->
                    <DataGridTemplateColumn Header="Пользователь" Width="190">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center" Margin="14,0">
                                    <TextBlock Text="{Binding UserFullName}"
                                               FontSize="12" Foreground="#1B2A4A"/>
                                    <TextBlock Text="{Binding UserLogin, StringFormat='@{0}'}"
                                               FontSize="10" Foreground="#8A94A6"
                                               Margin="0,1,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Роль -->
                    <DataGridTextColumn Header="Роль" Binding="{Binding RoleRu}" Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#3D4A60"/>
                                <Setter Property="Margin" Value="14,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Действие — цветной бейдж -->
                    <DataGridTemplateColumn Header="Действие" Width="155">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Margin="14,0" HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        CornerRadius="4" Padding="9,3">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#F0F4FB"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActionCode}" Value="LOGIN">
                                                    <Setter Property="Background" Value="#DFF6DD"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ActionCode}" Value="LOGOUT">
                                                    <Setter Property="Background" Value="#EDEBE9"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ActionCode}" Value="CREATE">
                                                    <Setter Property="Background" Value="#EFF6FC"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ActionCode}" Value="UPDATE">
                                                    <Setter Property="Background" Value="#FFF4CE"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ActionCode}" Value="SOFT_DELETE">
                                                    <Setter Property="Background" Value="#FDE7E9"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ActionCode}" Value="RESTORE">
                                                    <Setter Property="Background" Value="#EFF6FC"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ActionCode}" Value="VIEW">
                                                    <Setter Property="Background" Value="#F3F2F1"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ActionCode}" Value="ACCESS_DENIED">
                                                    <Setter Property="Background" Value="#FDE7E9"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding ActionRu}" FontSize="11"
                                               FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#5A667A"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ActionCode}" Value="LOGIN">
                                                        <Setter Property="Foreground" Value="#107C10"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ActionCode}" Value="CREATE">
                                                        <Setter Property="Foreground" Value="#0063B1"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ActionCode}" Value="UPDATE">
                                                        <Setter Property="Foreground" Value="#7A4F00"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ActionCode}" Value="SOFT_DELETE">
                                                        <Setter Property="Foreground" Value="#A4262C"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ActionCode}" Value="RESTORE">
                                                        <Setter Property="Foreground" Value="#0063B1"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ActionCode}" Value="ACCESS_DENIED">
                                                        <Setter Property="Foreground" Value="#A4262C"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Описание -->
                    <DataGridTextColumn Header="Описание"
                                        Binding="{Binding Description}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#3D4A60"/>
                                <Setter Property="Margin" Value="14,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- IP -->
                    <DataGridTextColumn Header="IP-адрес"
                                        Binding="{Binding IPAddress}" Width="115">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#8A94A6"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontFamily" Value="Consolas"/>
                                <Setter Property="Margin" Value="14,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>

    </Grid>
</Page>
