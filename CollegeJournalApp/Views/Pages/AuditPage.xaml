<Page x:Class="CollegeJournalApp.Views.Pages.AuditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#FAF9F8"
      FontFamily="Segoe UI"
      Title="Журнал аудита">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1" Padding="24,14">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Журнал действий в системе"
                           FontSize="18" FontWeight="SemiBold" Foreground="#1F1F1F"/>
                <TextBlock x:Name="TxtTotal" Text=""
                           FontSize="12" Foreground="#605E5C"
                           VerticalAlignment="Bottom" Margin="10,0,0,2"/>
            </StackPanel>
        </Border>

        <!-- Фильтры -->
        <Border Grid.Row="1" Background="White" Padding="24,10"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Border BorderBrush="#D0D0D0" BorderThickness="1" Width="220" Height="30" Margin="0,0,8,0">
                    <TextBox x:Name="TxtSearch" BorderThickness="0" Padding="8,6"
                             FontSize="12" Background="White"
                             TextChanged="Filter_Changed">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="Поиск по пользователю..."
                                                                   Foreground="#A19F9D" FontSize="12"
                                                                   FontFamily="Segoe UI" Margin="8,6,0,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Border>

                <ComboBox x:Name="CmbAction" Width="160" Height="30" Margin="0,0,8,0"
                          FontSize="12" SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="Все действия" IsSelected="True"/>
                    <ComboBoxItem Content="Вход в систему"/>
                    <ComboBoxItem Content="Добавление записи"/>
                    <ComboBoxItem Content="Изменение записи"/>
                    <ComboBoxItem Content="Удаление записи"/>
                    <ComboBoxItem Content="Просмотр данных"/>
                    <ComboBoxItem Content="Отказано в доступе"/>
                </ComboBox>

                <Button Content="Обновить" Click="BtnRefresh_Click"
                        Height="30" Padding="14,0"
                        Background="White" Foreground="#323130"
                        BorderBrush="#D0D0D0" BorderThickness="1"
                        FontFamily="Segoe UI" FontSize="12" Cursor="Hand"/>

                <TextBlock Text="Двойной клик по записи — подробная информация"
                           FontSize="11" Foreground="#A19F9D"
                           VerticalAlignment="Center" Margin="16,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Таблица -->
        <Border Grid.Row="2" Margin="24,16,24,0"
                Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
            <DataGrid x:Name="AuditGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#F3F2F1"
                      BorderThickness="0"
                      Background="White" RowBackground="White"
                      AlternatingRowBackground="#FAFAFA"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      CanUserResizeRows="False"
                      FontFamily="Segoe UI" FontSize="12"
                      RowHeight="34"
                      MouseDoubleClick="AuditGrid_DoubleClick">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F3F2F1"/>
                        <Setter Property="Foreground" Value="#605E5C"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="BorderBrush" Value="#E0E0E0"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="12,0"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#EFF6FC"/>
                                <Setter Property="Foreground" Value="#1F1F1F"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Cursor" Value="Hand"/>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Дата и время" Binding="{Binding ActionAt}"  Width="130"/>
                    <DataGridTextColumn Header="Пользователь" Binding="{Binding UserFullName}" Width="180"/>
                    <DataGridTextColumn Header="Роль"         Binding="{Binding RoleRu}"    Width="110"/>
                    <DataGridTextColumn Header="Действие"     Binding="{Binding ActionRu}"  Width="140"/>
                    <DataGridTextColumn Header="Описание"     Binding="{Binding Description}" Width="*"/>
                    <DataGridTextColumn Header="IP"           Binding="{Binding IPAddress}"  Width="110"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock Grid.Row="3" Text="Двойной клик по строке — открыть подробности"
                   FontSize="11" Foreground="#A19F9D"
                   HorizontalAlignment="Right" Margin="0,6,28,10"/>
    </Grid>
</Page>
