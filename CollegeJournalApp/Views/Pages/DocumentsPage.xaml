<Page x:Class="CollegeJournalApp.Views.Pages.DocumentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F4F6FA"
      FontFamily="Segoe UI"
      Title="Документы">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- header -->
            <RowDefinition Height="Auto"/>
            <!-- admin requests banner -->
            <RowDefinition Height="Auto"/>
            <!-- mode selector -->
            <RowDefinition Height="*"/>
            <!-- content -->
        </Grid.RowDefinitions>

        <!-- ══ Заголовок ══ -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="#E3E6EE" BorderThickness="0,0,0,1"
                Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Border Width="36" Height="36" CornerRadius="8"
                            Background="#EFF6FC" Margin="0,0,12,0">
                        <TextBlock Text="📄" FontSize="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Документы"
                                   FontSize="17" FontWeight="SemiBold"
                                   Foreground="#1B2A4A"/>
                        <TextBlock x:Name="TxtPageSubtitle"
                                   FontSize="11" Foreground="#8A94A6"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Кнопка запросов (только Админ) -->
                <Button x:Name="BtnPendingRequests"
                        Grid.Column="1"
                        Visibility="Collapsed"
                        Click="BtnPendingRequests_Click"
                        Height="34" Padding="14,0"
                        FontSize="12" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bdr" Background="#FFF4CE"
                                    CornerRadius="7" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⏳" FontSize="13"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <TextBlock x:Name="TxtPendingCount"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="#7A4F00"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bdr" Property="Background" Value="#FFE9A0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ══ Уведомления куратора ══ -->
        <Border x:Name="BannerNotifs" Grid.Row="1"
                Visibility="Collapsed"
                Background="#EFF6FC"
                BorderBrush="#BDD7EE" BorderThickness="0,0,0,1"
                Padding="20,10">
            <StackPanel x:Name="PanelNotifs"/>
        </Border>

        <!-- ══ Переключатель режима ══ -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="#E3E6EE" BorderThickness="0,0,0,1"
                Padding="20,0">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnModePersonal"
                        Content="📁  Личные документы"
                        Click="BtnModePersonal_Click"
                        Height="40" Padding="16,0"
                        FontSize="12" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bdr" BorderBrush="#0078D4"
                                    BorderThickness="0,0,0,3"
                                    Padding="{TemplateBinding Padding}"
                                    Background="Transparent">
                                <TextBlock Text="{TemplateBinding Content}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="#0078D4"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bdr" Property="Background" Value="#EBF3FB"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="BtnModeGeneral"
                        Content="📋  Общие документы"
                        Click="BtnModeGeneral_Click"
                        Height="40" Padding="16,0"
                        FontSize="12" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bdr" BorderBrush="Transparent"
                                    BorderThickness="0,0,0,3"
                                    Padding="{TemplateBinding Padding}"
                                    Background="Transparent">
                                <TextBlock Text="{TemplateBinding Content}"
                                           FontSize="12"
                                           Foreground="#5A667A"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bdr" Property="Background" Value="#F5F8FF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <!-- ══ Контент ══ -->
        <Grid Grid.Row="3">

            <!-- ─── Режим: Личные документы ─── -->
            <Grid x:Name="PanelPersonal">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="270" MinWidth="200" MaxWidth="360"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Левая панель: список студентов -->
                <Border Grid.Column="0" Background="White"
                        BorderBrush="#E3E6EE" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Padding="12,10,12,6"
                                BorderBrush="#EEF1F7" BorderThickness="0,0,0,1">
                            <Border BorderBrush="#D0D8E8" BorderThickness="1"
                                    CornerRadius="6" Background="White">
                                <ComboBox x:Name="CmbDocGroup"
                                          BorderThickness="0" Background="Transparent"
                                          FontSize="12" Padding="8,6"
                                          SelectionChanged="CmbDocGroup_SelectionChanged"/>
                            </Border>
                        </Border>

                        <Border Grid.Row="1" Padding="12,6,12,8">
                            <Border BorderBrush="#D0D8E8" BorderThickness="1"
                                    CornerRadius="6" Background="White">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="🔍"
                                               FontSize="11" Foreground="#8A94A6"
                                               VerticalAlignment="Center" Margin="8,0,5,0"/>
                                    <TextBox x:Name="TxtDocSearch"
                                             Grid.Column="1"
                                             BorderThickness="0" Padding="0,7,8,7"
                                             FontSize="12" Background="Transparent"
                                             VerticalAlignment="Center"
                                             TextChanged="TxtDocSearch_Changed">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Style.Triggers>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                                    <VisualBrush.Visual>
                                                                        <TextBlock Text="Поиск студента…"
                                                                                   Foreground="#B0B8C8"
                                                                                   FontSize="12"
                                                                                   FontFamily="Segoe UI"
                                                                                   Margin="0,7,0,0"/>
                                                                    </VisualBrush.Visual>
                                                                </VisualBrush>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Grid>
                            </Border>
                        </Border>

                        <ListBox x:Name="DocStudentList"
                                 Grid.Row="2"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionChanged="DocStudentList_SelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Bdr" Background="Transparent"
                                                        BorderBrush="#EEF1F7"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="12,10" Cursor="Hand">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bdr" Property="Background" Value="#F5F8FF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bdr" Property="Background" Value="#EFF6FC"/>
                                                        <Setter TargetName="Bdr" Property="BorderBrush" Value="#BDD7EE"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="32" Height="32"
                                                CornerRadius="16" Background="#EFF6FC">
                                            <TextBlock Text="{Binding Initial}"
                                                       FontSize="13" FontWeight="Bold"
                                                       Foreground="#0078D4"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                    Margin="10,0,0,0">
                                            <TextBlock Text="{Binding ShortName}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#1B2A4A"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding GroupName}"
                                                       FontSize="10.5" Foreground="#8A94A6"
                                                       Margin="0,1,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1" Width="5"
                              Background="Transparent"
                              VerticalAlignment="Stretch"
                              HorizontalAlignment="Center"
                              Cursor="SizeWE"
                              ResizeDirection="Columns"/>

                <!-- Правая панель -->
                <Grid Grid.Column="2">

                    <!-- Пустое состояние -->
                    <StackPanel x:Name="DocEmptyState"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock Text="📄" FontSize="48"
                                   HorizontalAlignment="Center" Margin="0,0,0,14"/>
                        <TextBlock Text="Выберите студента"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="#3D4A60"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Список студентов — в левой панели"
                                   FontSize="13" Foreground="#8A94A6"
                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- Нет доступа (куратор) -->
                    <StackPanel x:Name="DocNoAccess"
                                Visibility="Collapsed"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                MaxWidth="380">
                        <Border Width="72" Height="72" CornerRadius="36"
                                Background="#FFF4CE" HorizontalAlignment="Center"
                                Margin="0,0,0,16">
                            <TextBlock Text="🔒" FontSize="32"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="TxtNoAccessTitle"
                                   Text="Доступ закрыт"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="#3D4A60"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtNoAccessSub"
                                   Text="Для просмотра личных документов необходимо разрешение администратора"
                                   FontSize="13" Foreground="#8A94A6"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   Margin="0,8,0,24"/>
                        <Button x:Name="BtnRequestAccess"
                                Content="Запросить доступ"
                                Click="BtnRequestAccess_Click"
                                HorizontalAlignment="Center"
                                Height="36" Padding="24,0"
                                FontSize="13" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bdr" Background="#0078D4"
                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="{TemplateBinding Content}"
                                                   Foreground="White" FontSize="13"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bdr" Property="Background" Value="#106EBE"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="Bdr" Property="Background" Value="#A0B8D0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <!-- Документы студента (доступ есть) -->
                    <Grid x:Name="DocContent" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Панель управления -->
                        <Border Grid.Row="0" Background="White"
                                BorderBrush="#E3E6EE" BorderThickness="0,0,0,1"
                                Padding="20,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtDocStudentName"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="#1B2A4A"
                                               VerticalAlignment="Center"/>
                                    <Border x:Name="BdrAccessBadge"
                                            Visibility="Collapsed"
                                            Background="#DFF6DD" CornerRadius="10"
                                            Padding="10,3" Margin="12,0,0,0"
                                            VerticalAlignment="Center">
                                        <TextBlock x:Name="TxtAccessExpiry"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="#107C10"/>
                                    </Border>
                                </StackPanel>
                                <Button x:Name="BtnUploadDoc"
                                        Grid.Column="1"
                                        Content="⬆  Загрузить файл"
                                        Click="BtnUploadDoc_Click"
                                        Height="32" Padding="14,0"
                                        FontSize="12" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bdr" Background="#0078D4"
                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <TextBlock Text="{TemplateBinding Content}"
                                                           Foreground="White" FontSize="12"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bdr" Property="Background" Value="#106EBE"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Список документов -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="PanelDocs" Margin="20,12,20,12"/>
                        </ScrollViewer>
                    </Grid>

                </Grid>
            </Grid>

            <!-- ─── Режим: Общие документы ─── -->
            <Grid x:Name="PanelGeneral" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White"
                        BorderBrush="#E3E6EE" BorderThickness="0,0,0,1"
                        Padding="20,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   FontSize="13" Foreground="#5A667A"
                                   VerticalAlignment="Center"
                                   x:Name="TxtGeneralCount"/>
                        <Button x:Name="BtnUploadGeneral"
                                Grid.Column="1"
                                Visibility="Collapsed"
                                Content="⬆  Загрузить документ"
                                Click="BtnUploadGeneral_Click"
                                Height="32" Padding="14,0"
                                FontSize="12" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bdr" Background="#0078D4"
                                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="{TemplateBinding Content}"
                                                   Foreground="White" FontSize="12"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bdr" Property="Background" Value="#106EBE"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="PanelGeneral2" Margin="20,12,20,12"/>
                </ScrollViewer>
            </Grid>

        </Grid>
    </Grid>
</Page>
