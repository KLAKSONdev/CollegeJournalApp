<Page x:Class="CollegeJournalApp.Views.Pages.SchedulePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#FAF9F8" FontFamily="Segoe UI" Title="Расписание">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1" Padding="24,14">
            <TextBlock Text="Расписание занятий" FontSize="18"
                       FontWeight="SemiBold" Foreground="#1F1F1F"/>
        </Border>

        <!-- Панель инструментов -->
        <Border Grid.Row="1" Background="White" Padding="16,10"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Фильтр по группе — только Admin -->
                <StackPanel x:Name="PanelGroupFilter"
                            Orientation="Horizontal" Visibility="Collapsed" Margin="0,0,8,0">
                    <TextBlock Text="Группа:" FontSize="12" Foreground="#605E5C"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="CmbGroup" Width="160" Height="30" FontSize="12"/>
                </StackPanel>

                <!-- Фильтр по преподавателю — только Admin -->
                <StackPanel x:Name="PanelTeacherFilter"
                            Orientation="Horizontal" Visibility="Collapsed" Margin="0,0,8,0">
                    <TextBlock Text="Преподаватель:" FontSize="12" Foreground="#605E5C"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="CmbTeacher" Width="180" Height="30" FontSize="12"/>
                </StackPanel>

                <!-- Найти — только Admin -->
                <Button x:Name="BtnSearch" Content="🔍 Найти"
                        Visibility="Collapsed" Width="90" Height="30" Margin="0,0,8,0"
                        FontSize="12" Background="#0078D4" Foreground="White"
                        BorderThickness="0" Cursor="Hand" Click="BtnSearch_Click"/>

                <!-- Шаблон Excel — только Admin -->
                <Button x:Name="BtnTemplate" Content="📋 Шаблон"
                        Visibility="Collapsed" Width="100" Height="30" Margin="0,0,8,0"
                        FontSize="12" Background="#107C10" Foreground="White"
                        BorderThickness="0" Cursor="Hand" Click="BtnTemplate_Click"/>

                <!-- Импорт — Admin и Headman -->
                <Button x:Name="BtnImport" Content="📥 Загрузить из Excel"
                        Visibility="Collapsed" Width="160" Height="30" Margin="0,0,12,0"
                        FontSize="12" Background="#605E5C" Foreground="White"
                        BorderThickness="0" Cursor="Hand" Click="BtnImport_Click"/>

                <TextBlock x:Name="TxtTotal" FontSize="12" Foreground="#605E5C"
                           VerticalAlignment="Center"/>
            </WrapPanel>
        </Border>

        <!-- Контент -->
        <Grid Grid.Row="2">
            <StackPanel x:Name="EmptyState"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="TxtEmpty" FontSize="14" Foreground="#96948F"
                           HorizontalAlignment="Center" TextAlignment="Center"/>
            </StackPanel>

            <ScrollViewer x:Name="CardsScroll"
                          VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                <Grid x:Name="DayCardsGrid" Margin="12"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
