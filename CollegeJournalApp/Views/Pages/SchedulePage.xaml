<Page x:Class="CollegeJournalApp.Views.Pages.SchedulePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#FAF9F8" FontFamily="Segoe UI" Title="Расписание">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1" Padding="24,14">
            <TextBlock Text="Расписание занятий" FontSize="18"
                       FontWeight="SemiBold" Foreground="#1F1F1F"/>
        </Border>

        <!-- Фильтр по дню -->
        <Border Grid.Row="1" Background="White" Padding="24,10"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="CmbDay" Width="160" Height="30" Margin="0,0,8,0"
                          FontSize="12" SelectionChanged="CmbDay_Changed">
                    <ComboBoxItem Content="Все дни" IsSelected="True"/>
                    <ComboBoxItem Content="Понедельник"/>
                    <ComboBoxItem Content="Вторник"/>
                    <ComboBoxItem Content="Среда"/>
                    <ComboBoxItem Content="Четверг"/>
                    <ComboBoxItem Content="Пятница"/>
                    <ComboBoxItem Content="Суббота"/>
                </ComboBox>
                <Button x:Name="BtnImport" Content="📥 Загрузить из Excel" Width="150" Height="30"
                        Margin="8,0,0,0" FontSize="12" Background="#0078D4" Foreground="White"
                        BorderThickness="0" Cursor="Hand" Click="BtnImport_Click"/>
                <TextBlock x:Name="TxtTotal" FontSize="12" Foreground="#605E5C"
                           VerticalAlignment="Center" Margin="16,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Контейнер для карточек дней -->
        <Border Grid.Row="2" Margin="24,16,24,16">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="DaysPanel" Orientation="Vertical"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
