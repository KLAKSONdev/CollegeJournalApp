<Page x:Class="CollegeJournalApp.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#FAF9F8" FontFamily="Segoe UI" Title="Главная">

    <Page.Resources>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#323130"/>
            <Setter Property="Margin"     Value="0,0,0,10"/>
        </Style>
        <!-- Стиль строк в списках без выделения -->
        <Style x:Key="PlainRow" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="Transparent"
                                BorderBrush="#F3F2F1" BorderThickness="0,0,0,1"
                                Padding="14,9">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Стиль строк с hover (для лент событий) -->
        <Style x:Key="HoverRow" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent"
                                BorderBrush="#F3F2F1" BorderThickness="0,0,0,1"
                                Padding="16,10">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F8F8F8"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EFF6FC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,24">

            <!-- ═══════════════════════════════════════
                 ЗАГОЛОВОК
            ═══════════════════════════════════════ -->
            <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Margin="0,0,0,20">
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="TxtGreeting"
                                   FontSize="18" FontWeight="SemiBold" Foreground="#1F1F1F"/>
                        <TextBlock x:Name="TxtSubtitle"
                                   FontSize="12" Foreground="#605E5C" Margin="0,3,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" x:Name="TxtDate"
                               FontSize="12" Foreground="#605E5C" VerticalAlignment="Bottom"/>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════
                 ADMIN: 8 KPI-КАРТОЧЕК (4 + 4)
            ═══════════════════════════════════════ -->
            <StackPanel x:Name="AdminStatsPanel" Visibility="Collapsed" Margin="0,0,0,20">

                <!-- Ряд 1: Пользователи / Студенты / Группы / Преподаватели -->
                <UniformGrid Columns="4" Margin="0,0,0,8">
                    <Border Margin="0,0,5,0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <Border Height="4" Background="#0078D4"/>
                            <StackPanel Margin="14,10,14,12">
                                <TextBlock x:Name="TxtAdminUsers" Text="—"
                                           FontSize="26" FontWeight="Bold" Foreground="#1F1F1F"/>
                                <TextBlock Text="Пользователей"
                                           FontSize="11" Foreground="#605E5C" Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Margin="3,0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <Border Height="4" Background="#0078D4"/>
                            <StackPanel Margin="14,10,14,12">
                                <TextBlock x:Name="TxtAdminStudents" Text="—"
                                           FontSize="26" FontWeight="Bold" Foreground="#1F1F1F"/>
                                <TextBlock Text="Студентов"
                                           FontSize="11" Foreground="#605E5C" Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Margin="3,0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <Border Height="4" Background="#0078D4"/>
                            <StackPanel Margin="14,10,14,12">
                                <TextBlock x:Name="TxtAdminGroups" Text="—"
                                           FontSize="26" FontWeight="Bold" Foreground="#1F1F1F"/>
                                <TextBlock Text="Активных групп"
                                           FontSize="11" Foreground="#605E5C" Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Margin="5,0,0,0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <Border Height="4" Background="#8764B8"/>
                            <StackPanel Margin="14,10,14,12">
                                <TextBlock x:Name="TxtAdminTeachers" Text="—"
                                           FontSize="26" FontWeight="Bold" Foreground="#1F1F1F"/>
                                <TextBlock Text="Преподавателей"
                                           FontSize="11" Foreground="#605E5C" Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Ряд 2: Средний балл / Входов / Действий / Новых за месяц -->
                <UniformGrid Columns="4">
                    <Border Margin="0,0,5,0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <Border Height="4" Background="#107C10"/>
                            <StackPanel Margin="14,10,14,12">
                                <TextBlock x:Name="TxtAdminAvg" Text="—"
                                           FontSize="26" FontWeight="Bold" Foreground="#1F1F1F"/>
                                <TextBlock Text="Средний балл"
                                           FontSize="11" Foreground="#605E5C" Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Margin="3,0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <Border Height="4" Background="#CA5010"/>
                            <StackPanel Margin="14,10,14,12">
                                <TextBlock x:Name="TxtAdminLogins" Text="—"
                                           FontSize="26" FontWeight="Bold" Foreground="#1F1F1F"/>
                                <TextBlock Text="Входов сегодня"
                                           FontSize="11" Foreground="#605E5C" Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Margin="3,0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <Border Height="4" Background="#CA5010"/>
                            <StackPanel Margin="14,10,14,12">
                                <TextBlock x:Name="TxtAdminActions" Text="—"
                                           FontSize="26" FontWeight="Bold" Foreground="#1F1F1F"/>
                                <TextBlock Text="Действий сегодня"
                                           FontSize="11" Foreground="#605E5C" Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Margin="5,0,0,0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <Border Height="4" Background="#0078D4"/>
                            <StackPanel Margin="14,10,14,12">
                                <TextBlock x:Name="TxtAdminNewUsers" Text="—"
                                           FontSize="26" FontWeight="Bold" Foreground="#1F1F1F"/>
                                <TextBlock Text="Новых за месяц"
                                           FontSize="11" Foreground="#605E5C" Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>

            <!-- ═══════════════════════════════════════
                 ADMIN: ОСНОВНОЙ КОНТЕНТ
            ═══════════════════════════════════════ -->
            <StackPanel x:Name="AdminDashboardBody" Visibility="Collapsed">

                <!-- ── Ряд 1: Успеваемость по группам  +  Посещаемость сегодня ── -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Успеваемость по группам -->
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Успеваемость по группам"
                                   Style="{StaticResource SectionTitle}"/>
                        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                            <StackPanel>
                                <!-- Шапка таблицы -->
                                <Grid Background="#F3F2F1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="46"/>
                                        <ColumnDefinition Width="58"/>
                                        <ColumnDefinition Width="64"/>
                                        <ColumnDefinition Width="54"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Группа"
                                               Margin="14,7,0,7" FontSize="11" FontWeight="SemiBold" Foreground="#605E5C"/>
                                    <TextBlock Grid.Column="1" Text="Студ."
                                               Margin="0,7" FontSize="11" FontWeight="SemiBold" Foreground="#605E5C" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Ср. балл"
                                               Margin="0,7" FontSize="11" FontWeight="SemiBold" Foreground="#605E5C" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="✗ Двоек"
                                               Margin="0,7" FontSize="10" FontWeight="SemiBold" Foreground="#D13438" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="★ Отл."
                                               Margin="0,7,10,7" FontSize="10" FontWeight="SemiBold" Foreground="#107C10" HorizontalAlignment="Center"/>
                                </Grid>
                                <!-- Строки групп -->
                                <ListBox x:Name="GroupStatsList"
                                         BorderThickness="0" Background="Transparent"
                                         MaxHeight="250"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ItemContainerStyle="{StaticResource PlainRow}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="46"/>
                                                    <ColumnDefinition Width="58"/>
                                                    <ColumnDefinition Width="64"/>
                                                    <ColumnDefinition Width="54"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="14,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding GroupName}"
                                                               FontSize="12" Foreground="#1F1F1F" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding CourseLine}"
                                                               FontSize="10" Foreground="#A19F9D"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding StudentCount}"
                                                           FontSize="12" Foreground="#605E5C"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding AvgGradeStr}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{Binding AvgColor}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="3" Text="{Binding FailCount}"
                                                           FontSize="12" Foreground="#D13438"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="4" Text="{Binding ExcellentPctStr}"
                                                           FontSize="11" Foreground="#107C10"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Margin="0,0,10,0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock x:Name="TxtNoGroupStats"
                                           Text="Данных об оценках пока нет"
                                           FontSize="12" Foreground="#A19F9D"
                                           HorizontalAlignment="Center"
                                           Margin="0,16,0,16" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Посещаемость сегодня -->
                    <StackPanel Grid.Column="1">
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Посещаемость сегодня"
                                       Style="{StaticResource SectionTitle}" Margin="0"/>
                            <TextBlock x:Name="TxtTodayDate" Grid.Column="1"
                                       FontSize="11" Foreground="#A19F9D" VerticalAlignment="Center"/>
                        </Grid>
                        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                            <StackPanel>
                                <ListBox x:Name="AttendanceList"
                                         BorderThickness="0" Background="Transparent"
                                         MaxHeight="250"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ItemContainerStyle="{StaticResource PlainRow}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <Grid Margin="0,0,0,5">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding GroupName}"
                                                               FontSize="12" Foreground="#1F1F1F" FontWeight="SemiBold"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Summary}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{Binding PctColor}"/>
                                                </Grid>
                                                <!-- Полоса прогресса -->
                                                <Grid Height="6" Background="#EBEBEB" Margin="0,0,0,4">
                                                    <Rectangle HorizontalAlignment="Left"
                                                               Width="{Binding BarWidth}" Height="6"
                                                               Fill="{Binding BarColor}"
                                                               RadiusX="3" RadiusY="3"/>
                                                </Grid>
                                                <TextBlock Text="{Binding DetailLine}"
                                                           FontSize="10" Foreground="#A19F9D"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock x:Name="TxtNoAttendance"
                                           Text="Посещаемость за сегодня не внесена"
                                           FontSize="12" Foreground="#A19F9D"
                                           HorizontalAlignment="Center"
                                           Margin="0,16,0,16" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- ── Ряд 2: Лента действий  +  Тревоги ── -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Лента действий (аудит) -->
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Последние действия в системе"
                                       Style="{StaticResource SectionTitle}" Margin="0"/>
                            <TextBlock x:Name="TxtClickHint" Grid.Column="1"
                                       Text="Двойной клик — подробности"
                                       FontSize="10" Foreground="#A19F9D"
                                       VerticalAlignment="Center" Visibility="Collapsed"/>
                        </Grid>
                        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                            <ListBox x:Name="EventsList"
                                     BorderThickness="0" Background="Transparent"
                                     MaxHeight="300"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     MouseDoubleClick="EventsList_DoubleClick"
                                     ItemContainerStyle="{StaticResource HoverRow}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Rectangle Grid.Column="0" Width="3" Height="16"
                                                       Fill="{Binding DotColor}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Text}"
                                                       FontSize="12" Foreground="#323130"
                                                       TextWrapping="Wrap" Margin="10,0,0,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Time}"
                                                       FontSize="11" Foreground="#A19F9D"
                                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </StackPanel>

                    <!-- Тревоги -->
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="⚠ Требуют внимания"
                                   Style="{StaticResource SectionTitle}"/>
                        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                            <StackPanel>
                                <ListBox x:Name="AlertsList"
                                         BorderThickness="0" Background="Transparent"
                                         MaxHeight="300"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ItemContainerStyle="{StaticResource PlainRow}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="14"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0"
                                                         Width="10" Height="10"
                                                         Fill="{Binding AlertColor}"
                                                         VerticalAlignment="Top" Margin="0,3,0,0"/>
                                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                    <TextBlock Text="{Binding StudentName}"
                                                               FontSize="12" Foreground="#1F1F1F" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding GroupName}"
                                                               FontSize="10" Foreground="#A19F9D"/>
                                                    <TextBlock Text="{Binding AlertDetails}"
                                                               FontSize="11" Foreground="#605E5C"
                                                               Margin="0,2,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock x:Name="TxtNoAlerts"
                                           Text="✓ Проблемных студентов нет"
                                           FontSize="12" Foreground="#107C10"
                                           HorizontalAlignment="Center"
                                           Margin="0,16,0,16" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- ═══════════════════════════════════════
                 НЕ-ADMIN: 4 карточки + события + расписание
            ═══════════════════════════════════════ -->
            <StackPanel x:Name="NonAdminContent" Visibility="Collapsed">

                <!-- 4 карточки -->
                <UniformGrid x:Name="GroupStatsPanel" Columns="4" Margin="0,0,0,24">
                    <Border Margin="0,0,6,0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <Border x:Name="Card1Bar" Height="4" Background="#0078D4"/>
                            <StackPanel Margin="16,12,16,14">
                                <TextBlock x:Name="TxtCard1" Text="—"
                                           FontSize="28" FontWeight="SemiBold" Foreground="#1F1F1F"/>
                                <TextBlock x:Name="TxtLabel1" Text=""
                                           FontSize="11" Foreground="#605E5C" Margin="0,4,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Margin="3,0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <Border x:Name="Card2Bar" Height="4" Background="#107C10"/>
                            <StackPanel Margin="16,12,16,14">
                                <TextBlock x:Name="TxtCard2" Text="—"
                                           FontSize="28" FontWeight="SemiBold" Foreground="#1F1F1F"/>
                                <TextBlock x:Name="TxtLabel2" Text=""
                                           FontSize="11" Foreground="#605E5C" Margin="0,4,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Margin="3,0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <Border x:Name="Card3Bar" Height="4" Background="#CA5010"/>
                            <StackPanel Margin="16,12,16,14">
                                <TextBlock x:Name="TxtCard3" Text="—"
                                           FontSize="28" FontWeight="SemiBold" Foreground="#1F1F1F"/>
                                <TextBlock x:Name="TxtLabel3" Text=""
                                           FontSize="11" Foreground="#605E5C" Margin="0,4,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Margin="6,0,0,0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                        <StackPanel>
                            <Border x:Name="Card4Bar" Height="4" Background="#D13438"/>
                            <StackPanel Margin="16,12,16,14">
                                <TextBlock x:Name="TxtCard4" Text="—"
                                           FontSize="28" FontWeight="SemiBold" Foreground="#1F1F1F"/>
                                <TextBlock x:Name="TxtLabel4" Text=""
                                           FontSize="11" Foreground="#605E5C" Margin="0,4,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Лента событий  +  Расписание -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- События не-Admin -->
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="TxtEventsTitle" Margin="0,0,0,10"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#323130"/>
                        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                            <ListBox x:Name="NonAdminEventsList"
                                     BorderThickness="0" Background="Transparent"
                                     MaxHeight="340"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ItemContainerStyle="{StaticResource HoverRow}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Rectangle Grid.Column="0" Width="3" Height="16"
                                                       Fill="{Binding DotColor}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Text}"
                                                       FontSize="12" Foreground="#323130"
                                                       TextWrapping="Wrap" Margin="10,0,0,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Time}"
                                                       FontSize="11" Foreground="#A19F9D"
                                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </StackPanel>

                    <!-- Расписание на сегодня -->
                    <Border x:Name="SchedulePanel" Grid.Column="1"
                            Width="270" Margin="16,0,0,0"
                            VerticalAlignment="Top" Visibility="Collapsed">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Расписание на сегодня"
                                           FontSize="13" FontWeight="SemiBold" Foreground="#323130"/>
                                <TextBlock x:Name="TxtWeekday" Grid.Column="1"
                                           FontSize="11" Foreground="#A19F9D"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                                <ListBox x:Name="ScheduleList"
                                         BorderThickness="0" Background="Transparent"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ItemContainerStyle="{StaticResource PlainRow}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="22"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        Width="18" Height="18"
                                                        Background="#EFF6FC"
                                                        VerticalAlignment="Top" Margin="0,1,0,0">
                                                    <TextBlock Text="{Binding LessonNumber}"
                                                               FontSize="10" FontWeight="SemiBold"
                                                               Foreground="#0078D4"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                    <TextBlock Text="{Binding SubjectName}"
                                                               FontSize="12" Foreground="#1F1F1F"
                                                               TextWrapping="Wrap" FontWeight="SemiBold"/>
                                                    <TextBlock FontSize="10" Foreground="#605E5C" Margin="0,2,0,0">
                                                        <Run Text="{Binding StartTime}"/>
                                                        <Run Text="–"/>
                                                        <Run Text="{Binding EndTime}"/>
                                                        <Run Text=" · "/>
                                                        <Run Text="{Binding Classroom}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding TeacherShort}"
                                                               FontSize="10" Foreground="#A19F9D"
                                                               Margin="0,1,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                            <TextBlock x:Name="TxtNoLessons"
                                       Text="Сегодня занятий нет"
                                       FontSize="12" Foreground="#A19F9D"
                                       HorizontalAlignment="Center"
                                       Margin="0,16,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
