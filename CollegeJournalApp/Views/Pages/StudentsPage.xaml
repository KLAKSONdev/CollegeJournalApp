<Page x:Class="CollegeJournalApp.Views.Pages.StudentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#FAF9F8"
      FontFamily="Segoe UI"
      Title="Студенты">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛЕВАЯ ПАНЕЛЬ — список -->
        <Border Grid.Column="0" Background="#FFFFFF"
                BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Заголовок списка -->
                <Border Grid.Row="0" Padding="16,14,16,10"
                        BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Студенты" FontSize="15"
                                       FontWeight="SemiBold" Foreground="#1F1F1F"/>
                            <TextBlock x:Name="TxtStudentCount" Text=""
                                       FontSize="11" Foreground="#605E5C"
                                       VerticalAlignment="Bottom" Margin="8,0,0,1"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Поиск -->
                <Border Grid.Row="1" Padding="12,8"
                        BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                    <Border BorderBrush="#D0D0D0" BorderThickness="1">
                        <TextBox x:Name="TxtSearch"
                                 BorderThickness="0"
                                 Padding="8,6"
                                 FontSize="12"
                                 Foreground="#323130"
                                 Background="White"
                                 TextChanged="TxtSearch_TextChanged">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <VisualBrush Stretch="None" AlignmentX="Left">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="Поиск по ФИО..."
                                                                       Foreground="#A19F9D"
                                                                       FontSize="12"
                                                                       FontFamily="Segoe UI"
                                                                       Margin="8,6,0,0"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Border>
                </Border>

                <!-- Список студентов -->
                <ListBox x:Name="StudentsList"
                         Grid.Row="2"
                         BorderThickness="0"
                         Background="Transparent"
                         SelectionChanged="StudentsList_SelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="#F3F2F1"
                                                BorderThickness="0,0,0,1"
                                                Padding="14,10">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#EFF6FC"/>
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#0078D4"/>
                                                <Setter TargetName="Bd" Property="BorderThickness" Value="3,0,0,0"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#F8F8F8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding FullName}"
                                               FontSize="12" Foreground="#1F1F1F"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                    <Border Background="{Binding StatusColor}"
                                            Padding="5,1" Margin="0,0,6,0">
                                        <TextBlock Text="{Binding Status}"
                                                   FontSize="10" Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="{Binding StudyBasis}"
                                               FontSize="10" Foreground="#A19F9D"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ПРАВАЯ ПАНЕЛЬ — карточка студента -->
        <Grid Grid.Column="1">

            <!-- Заглушка когда никто не выбран -->
            <StackPanel x:Name="PanelEmpty"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <TextBlock Text="Выберите студента из списка"
                           FontSize="14" Foreground="#A19F9D"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Карточка студента -->
            <ScrollViewer x:Name="PanelCard"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,20,24,24">

                    <!-- Шапка карточки -->
                    <Border Background="White" BorderBrush="#E0E0E0"
                            BorderThickness="1" Padding="20,16"
                            Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="56"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Аватар -->
                            <Border Grid.Column="0" Width="48" Height="48"
                                    Background="#0078D4" CornerRadius="24">
                                <TextBlock x:Name="TxtAvatar"
                                           Foreground="White" FontSize="18"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <!-- Имя и статус -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                                <TextBlock x:Name="TxtCardName"
                                           FontSize="16" FontWeight="SemiBold"
                                           Foreground="#1F1F1F"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Border x:Name="BdrStatus" Background="#0078D4"
                                            Padding="7,2" Margin="0,0,8,0">
                                        <TextBlock x:Name="TxtCardStatus"
                                                   Foreground="White" FontSize="10"/>
                                    </Border>
                                    <TextBlock x:Name="TxtCardCode"
                                               Foreground="#605E5C" FontSize="11"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Зачётная книжка -->
                            <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                <TextBlock Text="Зачётная книжка"
                                           FontSize="10" Foreground="#A19F9D"
                                           HorizontalAlignment="Right"/>
                                <TextBlock x:Name="TxtCardStudentCode"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="#323130"
                                           HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ВКЛАДКИ КАРТОЧКИ -->
                    <TabControl x:Name="CardTabs" Background="White"
                                BorderBrush="#E0E0E0" BorderThickness="1">
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Padding" Value="14,8"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#605E5C"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Foreground" Value="#0078D4"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TabControl.Resources>

                        <!-- ВК1: ЛИЧНЫЕ ДАННЫЕ -->
                        <TabItem Header="Личные данные">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="450">
                                <StackPanel Margin="16,14">

                                    <TextBlock Text="ОСНОВНАЯ ИНФОРМАЦИЯ"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="#605E5C" Margin="0,0,0,10"/>

                                    <Grid x:Name="GridPersonal">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Дата рождения -->
                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,12">
                                            <TextBlock Text="Дата рождения" FontSize="10" Foreground="#A19F9D" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="TxtBirthDate" FontSize="12" Foreground="#1F1F1F"/>
                                        </StackPanel>

                                        <!-- Пол -->
                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                                            <TextBlock Text="Пол" FontSize="10" Foreground="#A19F9D" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="TxtGender" FontSize="12" Foreground="#1F1F1F"/>
                                        </StackPanel>

                                        <!-- Место рождения -->
                                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,12">
                                            <TextBlock Text="Место рождения" FontSize="10" Foreground="#A19F9D" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="TxtBirthPlace" FontSize="12" Foreground="#1F1F1F"/>
                                        </StackPanel>

                                        <!-- Гражданство -->
                                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                                            <TextBlock Text="Гражданство" FontSize="10" Foreground="#A19F9D" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="TxtCitizenship" FontSize="12" Foreground="#1F1F1F"/>
                                        </StackPanel>

                                        <!-- Адрес -->
                                        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,12">
                                            <TextBlock Text="Фактический адрес" FontSize="10" Foreground="#A19F9D" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="TxtAddress" FontSize="12" Foreground="#1F1F1F" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <!-- Телефон -->
                                        <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,12,12">
                                            <TextBlock Text="Телефон" FontSize="10" Foreground="#A19F9D" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="TxtPhone" FontSize="12" Foreground="#1F1F1F"/>
                                        </StackPanel>

                                        <!-- Email -->
                                        <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,12">
                                            <TextBlock Text="Email" FontSize="10" Foreground="#A19F9D" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="TxtEmail" FontSize="12" Foreground="#1F1F1F"/>
                                        </StackPanel>

                                        <!-- Общежитие -->
                                        <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,12,12">
                                            <TextBlock Text="Общежитие" FontSize="10" Foreground="#A19F9D" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="TxtDorm" FontSize="12" Foreground="#1F1F1F"/>
                                        </StackPanel>

                                        <!-- Основание -->
                                        <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,12">
                                            <TextBlock Text="Основание обучения" FontSize="10" Foreground="#A19F9D" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="TxtStudyBasis" FontSize="12" Foreground="#1F1F1F"/>
                                        </StackPanel>
                                    </Grid>

                                    <Rectangle Height="1" Fill="#E0E0E0" Margin="0,4,0,14"/>
                                    <TextBlock Text="ПАСПОРТНЫЕ ДАННЫЕ"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="#605E5C" Margin="0,0,0,10"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,12">
                                            <TextBlock Text="Серия и номер" FontSize="10" Foreground="#A19F9D" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="TxtPassport" FontSize="12" Foreground="#1F1F1F"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                                            <TextBlock Text="Дата выдачи" FontSize="10" Foreground="#A19F9D" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="TxtPassportDate" FontSize="12" Foreground="#1F1F1F"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,12">
                                            <TextBlock Text="Кем выдан" FontSize="10" Foreground="#A19F9D" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="TxtPassportBy" FontSize="12" Foreground="#1F1F1F" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,12,12">
                                            <TextBlock Text="СНИЛС" FontSize="10" Foreground="#A19F9D" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="TxtSnils" FontSize="12" Foreground="#1F1F1F"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,12">
                                            <TextBlock Text="Предыдущее учебное заведение" FontSize="10" Foreground="#A19F9D" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="TxtPrevSchool" FontSize="12" Foreground="#1F1F1F" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- ВК2: СОЦИАЛЬНАЯ КАРТОЧКА -->
                        <TabItem Header="Соц. карточка">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="450">
                                <StackPanel Margin="16,14">
                                    <TextBlock Text="ЗДОРОВЬЕ"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="#605E5C" Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,12,12">
                                            <TextBlock Text="Группа здоровья" FontSize="10" Foreground="#A19F9D" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="TxtHealthGroup" FontSize="12" Foreground="#1F1F1F"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,0,12">
                                            <TextBlock Text="Инвалидность" FontSize="10" Foreground="#A19F9D" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="TxtDisability" FontSize="12" Foreground="#1F1F1F"/>
                                        </StackPanel>
                                    </Grid>
                                    <StackPanel Margin="0,0,0,12">
                                        <TextBlock Text="Хронические заболевания" FontSize="10" Foreground="#A19F9D" Margin="0,0,0,3"/>
                                        <TextBlock x:Name="TxtChronic" FontSize="12" Foreground="#1F1F1F" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <Rectangle Height="1" Fill="#E0E0E0" Margin="0,4,0,14"/>
                                    <TextBlock Text="СОЦИАЛЬНЫЙ СТАТУС"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="#605E5C" Margin="0,0,0,10"/>

                                    <ItemsControl x:Name="SocialStatusList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#FFF4CE" Padding="8,4"
                                                        Margin="0,0,6,6" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding}" FontSize="11" Foreground="#7A4F00"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>

                                    <Rectangle Height="1" Fill="#E0E0E0" Margin="0,8,0,14"/>
                                    <TextBlock Text="СЕМЬЯ"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="#605E5C" Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,12,12">
                                            <TextBlock Text="Состав семьи" FontSize="10" Foreground="#A19F9D" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="TxtFamilyStructure" FontSize="12" Foreground="#1F1F1F"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,0,12">
                                            <TextBlock Text="Жилищные условия" FontSize="10" Foreground="#A19F9D" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="TxtHousing" FontSize="12" Foreground="#1F1F1F"/>
                                        </StackPanel>
                                    </Grid>
                                    <StackPanel Margin="0,0,0,12">
                                        <TextBlock Text="Доп. сведения" FontSize="10" Foreground="#A19F9D" Margin="0,0,0,3"/>
                                        <TextBlock x:Name="TxtSocialNotes" FontSize="12" Foreground="#1F1F1F" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- ВК3: РОДИТЕЛИ -->
                        <TabItem Header="Родители">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="450">
                                <ItemsControl x:Name="ParentsList" Margin="16,14">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F8F8F8" BorderBrush="#E0E0E0"
                                                    BorderThickness="1" Padding="14,12"
                                                    Margin="0,0,0,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,10">
                                                        <TextBlock Text="{Binding Relation}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="#0078D4" Margin="0,0,10,0"/>
                                                        <TextBlock Text="{Binding FullName}"
                                                                   FontSize="12" Foreground="#1F1F1F"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,8">
                                                        <TextBlock Text="Телефон" FontSize="10" Foreground="#A19F9D" Margin="0,0,0,2"/>
                                                        <TextBlock Text="{Binding Phone}" FontSize="12" Foreground="#1F1F1F"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                                                        <TextBlock Text="Раб. телефон" FontSize="10" Foreground="#A19F9D" Margin="0,0,0,2"/>
                                                        <TextBlock Text="{Binding WorkPhone}" FontSize="12" Foreground="#1F1F1F"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,12,8">
                                                        <TextBlock Text="Место работы" FontSize="10" Foreground="#A19F9D" Margin="0,0,0,2"/>
                                                        <TextBlock Text="{Binding Workplace}" FontSize="12" Foreground="#1F1F1F" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,8">
                                                        <TextBlock Text="Должность" FontSize="10" Foreground="#A19F9D" Margin="0,0,0,2"/>
                                                        <TextBlock Text="{Binding Position}" FontSize="12" Foreground="#1F1F1F"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2">
                                                        <TextBlock Text="Образование" FontSize="10" Foreground="#A19F9D" Margin="0,0,0,2"/>
                                                        <TextBlock Text="{Binding Education}" FontSize="12" Foreground="#1F1F1F"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>

                        <!-- ВК4: ОЦЕНКИ -->
                        <TabItem Header="Успеваемость">
                            <Border Padding="16,14">
                                <DataGrid x:Name="GradesGrid"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="#F3F2F1"
                                          BorderThickness="1"
                                          BorderBrush="#E0E0E0"
                                          Background="White"
                                          RowBackground="White"
                                          AlternatingRowBackground="#FAFAFA"
                                          HeadersVisibility="Column"
                                          CanUserResizeRows="False"
                                          FontFamily="Segoe UI"
                                          FontSize="12"
                                          RowHeight="32"
                                          MaxHeight="400">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#F3F2F1"/>
                                            <Setter Property="Foreground" Value="#605E5C"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Padding" Value="10,6"/>
                                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="10,0"/>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Дисциплина"  Binding="{Binding SubjectName}" Width="*"/>
                                        <DataGridTextColumn Header="Тип"         Binding="{Binding GradeType}"   Width="110"/>
                                        <DataGridTextColumn Header="Оценка"      Binding="{Binding GradeValue}"  Width="70"/>
                                        <DataGridTextColumn Header="Дата"        Binding="{Binding GradeDate}"   Width="90"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </TabItem>

                        <!-- ВК5: ПОСЕЩАЕМОСТЬ -->
                        <TabItem Header="Посещаемость">
                            <StackPanel Margin="16,14">
                                <!-- Статистика -->
                                <UniformGrid Columns="4" Margin="0,0,0,16">
                                    <Border Background="#F3F2F1" Padding="12,10" Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock x:Name="TxtPresent" Text="—" FontSize="20" FontWeight="SemiBold" Foreground="#107C10"/>
                                            <TextBlock Text="Присутствовал" FontSize="10" Foreground="#605E5C" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#F3F2F1" Padding="12,10" Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock x:Name="TxtAbsent" Text="—" FontSize="20" FontWeight="SemiBold" Foreground="#D13438"/>
                                            <TextBlock Text="Отсутствовал" FontSize="10" Foreground="#605E5C" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#F3F2F1" Padding="12,10" Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock x:Name="TxtLate" Text="—" FontSize="20" FontWeight="SemiBold" Foreground="#CA5010"/>
                                            <TextBlock Text="Опоздал" FontSize="10" Foreground="#605E5C" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#F3F2F1" Padding="12,10">
                                        <StackPanel>
                                            <TextBlock x:Name="TxtAttPercent" Text="—" FontSize="20" FontWeight="SemiBold" Foreground="#0078D4"/>
                                            <TextBlock Text="Процент" FontSize="10" Foreground="#605E5C" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <DataGrid x:Name="AttendanceGrid"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="#F3F2F1"
                                          BorderThickness="1" BorderBrush="#E0E0E0"
                                          Background="White" RowBackground="White"
                                          AlternatingRowBackground="#FAFAFA"
                                          HeadersVisibility="Column"
                                          CanUserResizeRows="False"
                                          FontFamily="Segoe UI" FontSize="12"
                                          RowHeight="32" MaxHeight="300">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="#F3F2F1"/>
                                            <Setter Property="Foreground" Value="#605E5C"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Padding" Value="10,6"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="10,0"/>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Дата"       Binding="{Binding LessonDate}" Width="100"/>
                                        <DataGridTextColumn Header="Дисциплина" Binding="{Binding Subject}"    Width="*"/>
                                        <DataGridTextColumn Header="Статус"     Binding="{Binding Status}"     Width="130"/>
                                        <DataGridTextColumn Header="Причина"    Binding="{Binding Reason}"     Width="150"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </TabItem>

                        <!-- ВК6: ДОСТИЖЕНИЯ -->
                        <TabItem Header="Достижения">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="450">
                                <ItemsControl x:Name="AchievementsList" Margin="16,14">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                                                    Padding="0,0,0,12" Margin="0,0,0,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding Title}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="#1F1F1F" TextWrapping="Wrap"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                            <Border Background="#EFF6FC" Padding="6,2" Margin="0,0,6,0">
                                                                <TextBlock Text="{Binding Category}" FontSize="10" Foreground="#0078D4"/>
                                                            </Border>
                                                            <Border Background="#F3F2F1" Padding="6,2">
                                                                <TextBlock Text="{Binding Level}" FontSize="10" Foreground="#605E5C"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Description}"
                                                                   FontSize="11" Foreground="#605E5C"
                                                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding AchieveDate}"
                                                               FontSize="11" Foreground="#A19F9D"
                                                               VerticalAlignment="Top" Margin="12,0,0,0"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>

                    </TabControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
