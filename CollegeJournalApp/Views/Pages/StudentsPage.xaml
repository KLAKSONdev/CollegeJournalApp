<Page x:Class="CollegeJournalApp.Views.Pages.StudentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#FAF9F8"
      FontFamily="Segoe UI"
      Title="Студенты">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#FFFFFF"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="24,14">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Студенты" FontSize="18" FontWeight="SemiBold" Foreground="#1F1F1F"/>
                <TextBlock x:Name="TxtStudentCount" Text=""
                           FontSize="12" Foreground="#605E5C"
                           VerticalAlignment="Bottom" Margin="10,0,0,2"/>
            </StackPanel>
        </Border>

        <!-- Фильтры -->
        <Border Grid.Row="1" Background="#FFFFFF" Padding="24,10"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">

                <!-- Поиск -->
                <Border BorderBrush="#D0D0D0" BorderThickness="1" Width="240" Height="30" Margin="0,0,8,0">
                    <TextBox x:Name="TxtSearch" BorderThickness="0" Padding="8,6"
                             FontSize="12" Foreground="#323130" Background="White"
                             TextChanged="Filter_Changed">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="Поиск по ФИО..."
                                                                   Foreground="#A19F9D" FontSize="12"
                                                                   FontFamily="Segoe UI" Margin="8,6,0,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Border>

                <!-- Фильтр по группе (только Admin) -->
                <ComboBox x:Name="CmbGroup"
                          Width="130" Height="30" Margin="0,0,8,0"
                          FontSize="12" Visibility="Collapsed"
                          SelectionChanged="Filter_Changed"/>

                <!-- Фильтр по основанию -->
                <ComboBox x:Name="CmbBasis"
                          Width="130" Height="30" Margin="0,0,8,0"
                          FontSize="12" SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="Все основания" IsSelected="True"/>
                    <ComboBoxItem Content="Бюджет"/>
                    <ComboBoxItem Content="Контракт"/>
                </ComboBox>

                <!-- Фильтр по полу -->
                <ComboBox x:Name="CmbGender"
                          Width="110" Height="30" Margin="0,0,8,0"
                          FontSize="12" SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="Все" IsSelected="True"/>
                    <ComboBoxItem Content="Мужской"/>
                    <ComboBoxItem Content="Женский"/>
                </ComboBox>

                <!-- Фильтр по общежитию -->
                <ComboBox x:Name="CmbDorm"
                          Width="150" Height="30" Margin="0,0,8,0"
                          FontSize="12" SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="Все студенты" IsSelected="True"/>
                    <ComboBoxItem Content="В общежитии"/>
                    <ComboBoxItem Content="Без общежития"/>
                </ComboBox>

                <!-- Сброс -->
                <Button x:Name="BtnReset" Content="Сбросить"
                        Height="30" Padding="12,0" Margin="0,0,0,0"
                        Background="Transparent" BorderBrush="#D0D0D0"
                        BorderThickness="1" FontFamily="Segoe UI"
                        FontSize="12" Foreground="#605E5C" Cursor="Hand"
                        Click="BtnReset_Click"/>

                <Border Width="1" Background="#E0E0E0" Margin="8,4"/>

                <Button x:Name="BtnExport" Content="&#x1F4E5; Экспорт в Excel"
                        Height="30" Padding="14,0"
                        Background="#107C10" Foreground="White"
                        BorderThickness="0"
                        FontFamily="Segoe UI" FontSize="12"
                        Cursor="Hand" Click="BtnExport_Click"/>
            </StackPanel>
        </Border>

        <!-- Таблица -->
        <Border Grid.Row="2" Margin="24,16,24,0"
                Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
            <DataGrid x:Name="StudentsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#F3F2F1"
                      BorderThickness="0"
                      Background="White" RowBackground="White"
                      AlternatingRowBackground="#FAFAFA"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      CanUserResizeRows="False"
                      FontFamily="Segoe UI" FontSize="12"
                      RowHeight="36"
                      MouseDoubleClick="StudentsGrid_DoubleClick">

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="ToolTip">
                            <Setter.Value>
                                <ToolTip Placement="Right" HorizontalOffset="8">
                                    <Border Background="White" BorderBrush="#E0E0E0"
                                            BorderThickness="1" CornerRadius="4"
                                            Padding="12" MinWidth="160">
                                        <StackPanel>
                                            <!-- Фото или инициалы -->
                                            <Grid Width="100" Height="100"
                                                  HorizontalAlignment="Center"
                                                  Margin="0,0,0,10">
                                                <Border Width="100" Height="100" CornerRadius="50"
                                                        Background="{Binding AvatarColor}">
                                                    <TextBlock Text="{Binding Initials}"
                                                               Foreground="White" FontSize="32"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <Border Width="100" Height="100" CornerRadius="50">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasPhoto}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Border.Clip>
                                                        <EllipseGeometry Center="50,50" RadiusX="50" RadiusY="50"/>
                                                    </Border.Clip>
                                                    <Image Source="{Binding Photo}" Stretch="UniformToFill"/>
                                                </Border>
                                            </Grid>
                                            <!-- ФИО -->
                                            <TextBlock Text="{Binding FullName}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#1F1F1F"
                                                       HorizontalAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       MaxWidth="160"
                                                       TextAlignment="Center"/>
                                            <!-- Группа и статус -->
                                            <TextBlock FontSize="11" Foreground="#605E5C"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,3,0,0">
                                                <Run Text="{Binding GroupName}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding Status}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </ToolTip>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F0F8FF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F3F2F1"/>
                        <Setter Property="Foreground" Value="#605E5C"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="BorderBrush" Value="#E0E0E0"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="12,0"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#EFF6FC"/>
                                <Setter Property="Foreground" Value="#1F1F1F"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="№"           Binding="{Binding RowNum}"      Width="44"/>
                    <DataGridTextColumn Header="ФИО"         Binding="{Binding FullName}"    Width="230"/>
                    <DataGridTextColumn Header="Группа"      Binding="{Binding GroupName}"   Width="90"/>
                    <DataGridTextColumn Header="Зач. книжка" Binding="{Binding StudentCode}" Width="100"/>
                    <DataGridTextColumn Header="Дата рожд."  Binding="{Binding BirthDate}"   Width="100"/>
                    <DataGridTextColumn Header="Пол"         Binding="{Binding Gender}"      Width="70"/>
                    <DataGridTextColumn Header="Основание"   Binding="{Binding StudyBasis}"  Width="90"/>
                    <DataGridTextColumn Header="Общежитие"   Binding="{Binding Dormitory}"   Width="120"/>
                    <DataGridTextColumn Header="Телефон"     Binding="{Binding Phone}"       Width="120"/>
                    <DataGridTextColumn Header="Статус"      Binding="{Binding Status}"      Width="90"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Подсказка -->
        <TextBlock x:Name="TxtHint"
                   Grid.Row="3"
                   Text="Двойной клик — открыть карточку студента"
                   FontSize="11" Foreground="#A19F9D"
                   HorizontalAlignment="Right"
                   Margin="0,6,28,10"/>
    </Grid>
</Page>
