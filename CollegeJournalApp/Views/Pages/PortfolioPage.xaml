<Page x:Class="CollegeJournalApp.Views.Pages.PortfolioPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F4F6FA"
      FontFamily="Segoe UI"
      Title="Портфолио">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ Заголовок страницы ══ -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="#E3E6EE" BorderThickness="0,0,0,1"
                Padding="24,14,24,14">
            <StackPanel Orientation="Horizontal">
                <Border Width="36" Height="36" CornerRadius="8"
                        Background="#EFF6FC" Margin="0,0,12,0">
                    <TextBlock Text="🎓" FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Портфолио студентов"
                               FontSize="17" FontWeight="SemiBold"
                               Foreground="#1B2A4A"/>
                    <TextBlock x:Name="TxtPageSubtitle"
                               FontSize="11" Foreground="#8A94A6"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══ Основной контент: левая панель + правая ══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270" MinWidth="200" MaxWidth="360"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Левая панель: список студентов ── -->
            <Border Grid.Column="0" Background="White"
                    BorderBrush="#E3E6EE" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Фильтр по группе -->
                    <Border Grid.Row="0" Padding="12,10,12,6"
                            BorderBrush="#EEF1F7" BorderThickness="0,0,0,1">
                        <Border BorderBrush="#D0D8E8" BorderThickness="1"
                                CornerRadius="6" Background="White">
                            <ComboBox x:Name="CmbGroup"
                                      BorderThickness="0" Background="Transparent"
                                      FontSize="12" Padding="8,6"
                                      SelectionChanged="CmbGroup_SelectionChanged"/>
                        </Border>
                    </Border>

                    <!-- Поиск по студентам -->
                    <Border Grid.Row="1" Padding="12,6,12,8">
                        <Border BorderBrush="#D0D8E8" BorderThickness="1"
                                CornerRadius="6" Background="White">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🔍"
                                           FontSize="11" Foreground="#8A94A6"
                                           VerticalAlignment="Center" Margin="8,0,5,0"/>
                                <TextBox x:Name="TxtStudentSearch"
                                         Grid.Column="1"
                                         BorderThickness="0" Padding="0,7,8,7"
                                         FontSize="12" Background="Transparent"
                                         VerticalAlignment="Center"
                                         TextChanged="TxtStudentSearch_Changed">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                                <VisualBrush.Visual>
                                                                    <TextBlock Text="Поиск студента…"
                                                                               Foreground="#B0B8C8" FontSize="12"
                                                                               FontFamily="Segoe UI" Margin="0,7,0,0"/>
                                                                </VisualBrush.Visual>
                                                            </VisualBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </Grid>
                        </Border>
                    </Border>

                    <!-- Список студентов -->
                    <ListBox x:Name="StudentList"
                             Grid.Row="2"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="StudentList_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bdr" Background="Transparent"
                                                    BorderBrush="#EEF1F7"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="12,10" Cursor="Hand">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bdr" Property="Background" Value="#F5F8FF"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bdr" Property="Background" Value="#EFF6FC"/>
                                                    <Setter TargetName="Bdr" Property="BorderBrush" Value="#BDD7EE"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Аватар -->
                                    <Border Grid.Column="0" Width="32" Height="32"
                                            CornerRadius="16" Background="#EFF6FC">
                                        <TextBlock Text="{Binding Initial}"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="#0078D4"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- ФИО + группа -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                Margin="10,0,4,0">
                                        <TextBlock Text="{Binding ShortName}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#1B2A4A"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding GroupName}"
                                                   FontSize="10.5" Foreground="#8A94A6"
                                                   Margin="0,1,0,0"/>
                                    </StackPanel>

                                    <!-- Бейдж достижений -->
                                    <Border Grid.Column="2"
                                            Background="#FFF4CE" CornerRadius="10"
                                            Padding="6,2" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AchievementCount}" Value="0">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding AchievementCount}"
                                                   FontSize="10" FontWeight="Bold"
                                                   Foreground="#7A4F00"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </Grid>
            </Border>

            <!-- Разделитель -->
            <GridSplitter Grid.Column="1" Width="5"
                          Background="Transparent"
                          VerticalAlignment="Stretch"
                          HorizontalAlignment="Center"
                          Cursor="SizeWE"
                          ResizeDirection="Columns"/>

            <!-- ── Правая панель: портфолио студента ── -->
            <Grid Grid.Column="2">

                <!-- Пустое состояние (нет выбора) -->
                <StackPanel x:Name="EmptyState"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <TextBlock Text="🎓" FontSize="52"
                               HorizontalAlignment="Center" Margin="0,0,0,14"/>
                    <TextBlock Text="Выберите студента"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="#3D4A60"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Список студентов — в левой панели"
                               FontSize="13" Foreground="#8A94A6"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Контент портфолио -->
                <Grid x:Name="PortfolioContent" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Шапка студента -->
                    <Border Grid.Row="0" Background="White"
                            BorderBrush="#E3E6EE" BorderThickness="0,0,0,1"
                            Padding="20,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Большой аватар -->
                            <Border Grid.Column="0" Width="52" Height="52"
                                    CornerRadius="26" Background="#EFF6FC"
                                    Margin="0,0,16,0">
                                <TextBlock x:Name="TxtAvatarBig"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="#0078D4"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TxtStudentFullName"
                                               FontSize="16" FontWeight="SemiBold"
                                               Foreground="#1B2A4A"
                                               VerticalAlignment="Center"/>
                                    <Border x:Name="BdrHeadman"
                                            Background="#FFF4CE" CornerRadius="4"
                                            Padding="7,2" Margin="10,0,0,0"
                                            Visibility="Collapsed"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="⭐ Староста" FontSize="10"
                                                   FontWeight="SemiBold" Foreground="#7A4F00"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock x:Name="TxtStudentGroup"
                                               FontSize="12" Foreground="#5A667A"/>
                                    <TextBlock x:Name="TxtStudentCode"
                                               FontSize="12" Foreground="#8A94A6"
                                               Margin="12,0,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Счётчики сводки -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Border Background="#EFF6FC" CornerRadius="8"
                                        Padding="12,6" Margin="0,0,8,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock x:Name="TxtSummaryGrade"
                                                   Text="—" FontSize="18"
                                                   FontWeight="Bold" Foreground="#0063B1"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="средний балл"
                                                   FontSize="10" Foreground="#8A94A6"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#DFF6DD" CornerRadius="8"
                                        Padding="12,6" Margin="0,0,8,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock x:Name="TxtSummaryAttendance"
                                                   Text="—" FontSize="18"
                                                   FontWeight="Bold" Foreground="#107C10"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="посещаемость"
                                                   FontSize="10" Foreground="#8A94A6"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#FFF4CE" CornerRadius="8"
                                        Padding="12,6">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock x:Name="TxtSummaryAchievements"
                                                   Text="0" FontSize="18"
                                                   FontWeight="Bold" Foreground="#7A4F00"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="достижений"
                                                   FontSize="10" Foreground="#8A94A6"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Вкладки -->
                    <TabControl Grid.Row="1" x:Name="PortfolioTabs"
                                Background="Transparent"
                                BorderBrush="#E3E6EE" BorderThickness="0,0,0,0">

                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Padding" Value="16,8"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                            <Border x:Name="Bdr"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="0,0,0,3"
                                                    Padding="{TemplateBinding Padding}"
                                                    Background="Transparent">
                                                <ContentPresenter ContentSource="Header"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bdr" Property="BorderBrush" Value="#0078D4"/>
                                                    <Setter TargetName="Bdr" Property="Background" Value="#EBF3FB"/>
                                                    <Setter Property="Foreground" Value="#0078D4"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bdr" Property="Background" Value="#F5F8FF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.Resources>

                        <!-- Вкладка 1: О студенте -->
                        <TabItem Header="👤  О студенте">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          Background="#F4F6FA">
                                <StackPanel x:Name="PanelAbout" Margin="20,16,20,16"/>
                            </ScrollViewer>
                        </TabItem>

                        <!-- Вкладка 2: Достижения -->
                        <TabItem Header="🏆  Достижения">
                            <Grid Background="#F4F6FA">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="White"
                                        BorderBrush="#E3E6EE" BorderThickness="0,0,0,1"
                                        Padding="20,10">
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="BtnAddAchievement"
                                                Content="＋  Добавить достижение"
                                                Click="BtnAddAchievement_Click"
                                                Height="32" Padding="14,0"
                                                FontSize="12" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bdr" Background="#0078D4"
                                                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                        <TextBlock Text="{TemplateBinding Content}"
                                                                   Foreground="White" FontSize="12"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bdr" Property="Background" Value="#106EBE"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <TextBlock x:Name="TxtAchievementCount"
                                                   FontSize="11" Foreground="#8A94A6"
                                                   VerticalAlignment="Center"
                                                   Margin="14,0,0,0"/>
                                    </StackPanel>
                                </Border>

                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="PanelAchievements"
                                                Margin="20,12,20,12"/>
                                </ScrollViewer>
                            </Grid>
                        </TabItem>

                        <!-- Вкладка 3: Успеваемость -->
                        <TabItem Header="📊  Успеваемость">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          Background="#F4F6FA">
                                <StackPanel x:Name="PanelGrades" Margin="20,16,20,16"/>
                            </ScrollViewer>
                        </TabItem>

                        <!-- Вкладка 4: Посещаемость -->
                        <TabItem Header="📅  Посещаемость">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          Background="#F4F6FA">
                                <StackPanel x:Name="PanelAttendance" Margin="20,16,20,16"/>
                            </ScrollViewer>
                        </TabItem>

                        <!-- Вкладка 5: Характеристика -->
                        <TabItem Header="📝  Характеристика">
                            <Grid Background="#F4F6FA">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Margin="20,16,20,8"
                                        Background="White" CornerRadius="10"
                                        BorderBrush="#E3E6EE" BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#C0CADE" BlurRadius="8"
                                                          ShadowDepth="1" Opacity="0.12" Direction="270"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0" Padding="16,12"
                                                BorderBrush="#EEF1F7" BorderThickness="0,0,0,1">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📝" FontSize="14"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0"/>
                                                <TextBlock Text="Педагогическая характеристика"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#1B2A4A"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>

                                        <TextBox x:Name="TxtCharacteristic"
                                                 Grid.Row="1"
                                                 BorderThickness="0"
                                                 Padding="16,12"
                                                 FontSize="13"
                                                 Background="Transparent"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 VerticalAlignment="Stretch"/>
                                    </Grid>
                                </Border>

                                <!-- Нижняя панель: статус + кнопка сохранить -->
                                <Border Grid.Row="1" Margin="20,0,20,16"
                                        Background="White" CornerRadius="8"
                                        BorderBrush="#E3E6EE" BorderThickness="1"
                                        Padding="14,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="TxtCharacteristicMeta"
                                                   Grid.Column="0"
                                                   FontSize="11" Foreground="#8A94A6"
                                                   VerticalAlignment="Center"/>
                                        <Button x:Name="BtnSaveCharacteristic"
                                                Grid.Column="1"
                                                Content="💾  Сохранить характеристику"
                                                Click="BtnSaveCharacteristic_Click"
                                                Height="32" Padding="14,0"
                                                FontSize="12" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bdr" Background="#107C10"
                                                            CornerRadius="7" Padding="{TemplateBinding Padding}">
                                                        <TextBlock Text="{TemplateBinding Content}"
                                                                   Foreground="White" FontSize="12"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bdr" Property="Background" Value="#0B5A0B"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="Bdr" Property="Background" Value="#074007"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>

                            </Grid>
                        </TabItem>

                    </TabControl>
                </Grid>

            </Grid>
        </Grid>
    </Grid>
</Page>
