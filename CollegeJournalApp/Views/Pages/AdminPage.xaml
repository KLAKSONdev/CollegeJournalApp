<Page x:Class="CollegeJournalApp.Views.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#FAF9F8"
      FontFamily="Segoe UI"
      Title="Управление">

    <Page.Resources>

        <!-- ══════════════════════════════════════
             КНОПКИ ТУЛБАРА
        ══════════════════════════════════════ -->
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryBtn"   TargetType="Button" BasedOn="{StaticResource ToolBtn}">
            <Setter Property="Background"  Value="#0078D4"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
        </Style>
        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource ToolBtn}">
            <Setter Property="Background"  Value="White"/>
            <Setter Property="Foreground"  Value="#323130"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
        </Style>
        <Style x:Key="DangerBtn"    TargetType="Button" BasedOn="{StaticResource ToolBtn}">
            <Setter Property="Background"  Value="White"/>
            <Setter Property="Foreground"  Value="#D13438"/>
            <Setter Property="BorderBrush" Value="#EDAEAE"/>
        </Style>

        <!-- ══════════════════════════════════════
             ТАБЛИЦЫ
        ══════════════════════════════════════ -->
        <Style x:Key="GridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#F8F8F8"/>
            <Setter Property="Foreground"      Value="#605E5C"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="14,10"/>
            <Setter Property="BorderBrush"     Value="#E8E8E8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style x:Key="GridCell" TargetType="DataGridCell">
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Padding"           Value="14,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#1F1F1F"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="GridRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F5F5"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EFF6FC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ══════════════════════════════════════
             БОКОВАЯ НАВИГАЦИЯ — TabItem
        ══════════════════════════════════════ -->
        <Style x:Key="NavItem" TargetType="TabItem">
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Foreground"      Value="#3B3A39"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Margin"          Value="8,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                BorderThickness="0"
                                Padding="12,8">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="#EBF3FB"/>
                                <Setter Property="Foreground" Value="#0078D4"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F3F3"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected"   Value="True"/>
                                    <Condition Property="IsMouseOver"  Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#DDE9F5"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TabControl — убираем стандартный хром, делаем сайдбар -->
        <Style x:Key="SidebarTabControl" TargetType="TabControl">
            <Setter Property="TabStripPlacement" Value="Left"/>
            <Setter Property="Background"        Value="Transparent"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Padding"           Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- ЛЕВАЯ ПАНЕЛЬ -->
                            <Border Grid.Column="0" Background="White"
                                    BorderBrush="#E8E8E8" BorderThickness="0,0,1,0">
                                <DockPanel>
                                    <!-- Логотип секции -->
                                    <Border DockPanel.Dock="Top"
                                            BorderBrush="#F0F0F0" BorderThickness="0,0,0,1"
                                            Padding="16,14">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="28" Height="28" Background="#0078D4"
                                                    CornerRadius="6" Margin="0,0,10,0">
                                                <TextBlock Text="⚙" FontSize="14" Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Управление"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#1F1F1F"/>
                                                <TextBlock Text="Администрирование"
                                                           FontSize="10" Foreground="#A19F9D"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Пункты навигации -->
                                    <ScrollViewer DockPanel.Dock="Bottom"
                                                  VerticalScrollBarVisibility="Auto">
                                        <StackPanel Margin="0,8,0,16">

                                            <!-- Группа: ОСНОВНЫЕ -->
                                            <TextBlock Text="ОСНОВНЫЕ"
                                                       FontSize="10" FontWeight="Bold"
                                                       Foreground="#BEBCBA"
                                                       Margin="20,8,0,4"/>
                                            <TabPanel x:Name="HeaderPanel"
                                                      IsItemsHost="True"
                                                      Background="Transparent"
                                                      FlowDirection="LeftToRight"/>
                                        </StackPanel>
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>

                            <!-- ПРАВЫЙ КОНТЕНТ -->
                            <Border Grid.Column="1" Background="#FAF9F8">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  ContentSource="SelectedContent"
                                                  Margin="0"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <!-- ══════════════════════════════════════════
         ШАПКА СТРАНИЦЫ
    ══════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                Padding="24,13">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Управление данными"
                               FontSize="18" FontWeight="SemiBold" Foreground="#1F1F1F"/>
                </StackPanel>
                <Border Grid.Column="1"
                        Background="#FFF4CE" BorderBrush="#F0D080"
                        BorderThickness="1" Padding="10,4" CornerRadius="4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠" Foreground="#8A6800" FontSize="11" Margin="0,0,6,0"/>
                        <TextBlock Text="Только для администратора"
                                   FontSize="11" Foreground="#8A6800" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════
             TABCONTROL — САЙДБАР + КОНТЕНТ
        ══════════════════════════════════════════ -->
        <TabControl Grid.Row="1"
                    Style="{StaticResource SidebarTabControl}">

            <!-- ═══ СТУДЕНТЫ ═══ -->
            <TabItem Style="{StaticResource NavItem}" x:Name="TabStudents">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="👤" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Студенты" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок секции -->
                    <Border Grid.Row="0" Background="White"
                            BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                            Padding="20,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Студенты" FontSize="15"
                                           FontWeight="SemiBold" Foreground="#1F1F1F"/>
                                <TextBlock Text="Список всех зачисленных студентов"
                                           FontSize="11" Foreground="#A19F9D" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock x:Name="TxtStudentsTotal" Grid.Column="1"
                                       FontSize="11" Foreground="#605E5C"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Тулбар -->
                    <Border Grid.Row="1" Background="#FAFAFA"
                            BorderBrush="#EFEFEF" BorderThickness="0,0,0,1"
                            Padding="20,8">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+ Добавить студента"
                                    Style="{StaticResource PrimaryBtn}"
                                    Margin="0,0,8,0" Click="BtnAddStudent_Click"/>
                            <Button Content="✎  Редактировать"
                                    Style="{StaticResource SecondaryBtn}"
                                    Margin="0,0,8,0" Click="BtnEditStudent_Click"/>
                            <Button Content="✕  Удалить"
                                    Style="{StaticResource DangerBtn}"
                                    Click="BtnDeleteStudent_Click"/>
                            <Rectangle Width="1" Fill="#E0E0E0" Margin="12,4"/>
                            <Border BorderBrush="#D8D8D8" BorderThickness="1"
                                    Width="210" Height="32">
                                <TextBox x:Name="TxtStudentSearch"
                                         BorderThickness="0" Padding="10,7"
                                         FontSize="12" Background="White"
                                         TextChanged="TxtStudentSearch_Changed">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                                <VisualBrush.Visual>
                                                                    <TextBlock Text="🔍  Поиск по ФИО..."
                                                                               Foreground="#A19F9D"
                                                                               FontFamily="Segoe UI"
                                                                               FontSize="12"
                                                                               Margin="10,7,0,0"/>
                                                                </VisualBrush.Visual>
                                                            </VisualBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Таблица -->
                    <DataGrid x:Name="StudentsAdminGrid" Grid.Row="2"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F0F0F0"
                              BorderThickness="0"
                              Background="White"
                              RowBackground="White"
                              AlternatingRowBackground="#FDFDFD"
                              HeadersVisibility="Column"
                              SelectionMode="Single"
                              CanUserResizeRows="False"
                              FontFamily="Segoe UI" FontSize="12"
                              RowHeight="38"
                              ColumnHeaderStyle="{StaticResource GridHeader}"
                              CellStyle="{StaticResource GridCell}"
                              RowStyle="{StaticResource GridRow}"
                              MouseDoubleClick="StudentsAdminGrid_DoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ФИО"           Binding="{Binding FullName}"    Width="220"/>
                            <DataGridTextColumn Header="Группа"        Binding="{Binding GroupName}"   Width="90"/>
                            <DataGridTextColumn Header="Зач. книжка"   Binding="{Binding StudentCode}" Width="100"/>
                            <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDate}"   Width="110"/>
                            <DataGridTextColumn Header="Пол"           Binding="{Binding Gender}"      Width="65"/>
                            <DataGridTextColumn Header="Основание"     Binding="{Binding StudyBasis}"  Width="90"/>
                            <DataGridTextColumn Header="Общежитие"     Binding="{Binding Dormitory}"   Width="130"/>
                            <DataGridTextColumn Header="Телефон"       Binding="{Binding Phone}"       Width="125"/>
                            <DataGridTextColumn Header="Статус"        Binding="{Binding Status}"      Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ═══ ГРУППЫ ═══ -->
            <TabItem Style="{StaticResource NavItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📚" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Группы" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="White"
                            BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Учебные группы" FontSize="15"
                                           FontWeight="SemiBold" Foreground="#1F1F1F"/>
                                <TextBlock Text="Управление группами и назначение кураторов"
                                           FontSize="11" Foreground="#A19F9D" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock x:Name="TxtGroupsTotal" Grid.Column="1"
                                       FontSize="11" Foreground="#605E5C"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Background="#FAFAFA"
                            BorderBrush="#EFEFEF" BorderThickness="0,0,0,1" Padding="20,8">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+ Добавить группу"
                                    Style="{StaticResource PrimaryBtn}"
                                    Margin="0,0,8,0" Click="BtnAddGroup_Click"/>
                            <Button Content="✎  Редактировать"
                                    Style="{StaticResource SecondaryBtn}"
                                    Margin="0,0,8,0" Click="BtnEditGroup_Click"/>
                            <Button Content="👤  Назначить куратора"
                                    Style="{StaticResource SecondaryBtn}"
                                    Margin="0,0,8,0" Click="BtnAssignCurator_Click"/>
                            <Button Content="✕  Удалить"
                                    Style="{StaticResource DangerBtn}"
                                    Click="BtnDeleteGroup_Click"/>
                        </StackPanel>
                    </Border>

                    <DataGrid x:Name="GroupsAdminGrid" Grid.Row="2"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F0F0F0"
                              BorderThickness="0" Background="White" RowBackground="White"
                              AlternatingRowBackground="#FDFDFD" HeadersVisibility="Column"
                              SelectionMode="Single" CanUserResizeRows="False"
                              FontFamily="Segoe UI" FontSize="12" RowHeight="38"
                              ColumnHeaderStyle="{StaticResource GridHeader}"
                              CellStyle="{StaticResource GridCell}"
                              RowStyle="{StaticResource GridRow}"
                              MouseDoubleClick="GroupsAdminGrid_DoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Группа"        Binding="{Binding GroupName}"     Width="90"/>
                            <DataGridTextColumn Header="Специальность" Binding="{Binding Specialty}"     Width="*"/>
                            <DataGridTextColumn Header="Код"           Binding="{Binding SpecialtyCode}" Width="90"/>
                            <DataGridTextColumn Header="Курс"          Binding="{Binding Course}"        Width="55"/>
                            <DataGridTextColumn Header="Семестр"       Binding="{Binding Semester}"      Width="70"/>
                            <DataGridTextColumn Header="Форма"         Binding="{Binding EduForm}"       Width="90"/>
                            <DataGridTextColumn Header="Основание"     Binding="{Binding EduBasis}"      Width="90"/>
                            <DataGridTextColumn Header="Куратор"       Binding="{Binding CuratorName}"   Width="170"/>
                            <DataGridTextColumn Header="Студентов"     Binding="{Binding StudentCount}"  Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ═══ ПОЛЬЗОВАТЕЛИ ═══ -->
            <TabItem Style="{StaticResource NavItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔑" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Пользователи" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="White"
                            BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Учётные записи" FontSize="15"
                                           FontWeight="SemiBold" Foreground="#1F1F1F"/>
                                <TextBlock Text="Управление доступом и ролями пользователей"
                                           FontSize="11" Foreground="#A19F9D" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock x:Name="TxtUsersTotal" Grid.Column="1"
                                       FontSize="11" Foreground="#605E5C"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Background="#FAFAFA"
                            BorderBrush="#EFEFEF" BorderThickness="0,0,0,1" Padding="20,8">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+ Добавить пользователя"
                                    Style="{StaticResource PrimaryBtn}"
                                    Margin="0,0,8,0" Click="BtnAddUser_Click"/>
                            <Button Content="✎  Редактировать"
                                    Style="{StaticResource SecondaryBtn}"
                                    Margin="0,0,8,0" Click="BtnEditUser_Click"/>
                            <Button Content="⊘  Блокировать / Разблокировать"
                                    Style="{StaticResource DangerBtn}"
                                    Click="BtnToggleUser_Click"/>
                        </StackPanel>
                    </Border>

                    <DataGrid x:Name="UsersAdminGrid" Grid.Row="2"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F0F0F0"
                              BorderThickness="0" Background="White" RowBackground="White"
                              AlternatingRowBackground="#FDFDFD" HeadersVisibility="Column"
                              SelectionMode="Single" CanUserResizeRows="False"
                              FontFamily="Segoe UI" FontSize="12" RowHeight="38"
                              ColumnHeaderStyle="{StaticResource GridHeader}"
                              CellStyle="{StaticResource GridCell}"
                              RowStyle="{StaticResource GridRow}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Логин"          Binding="{Binding Login}"     Width="130"/>
                            <DataGridTextColumn Header="ФИО"            Binding="{Binding FullName}"  Width="220"/>
                            <DataGridTextColumn Header="Роль"           Binding="{Binding Role}"      Width="120"/>
                            <DataGridTextColumn Header="Телефон"        Binding="{Binding Phone}"     Width="130"/>
                            <DataGridTextColumn Header="Email"          Binding="{Binding Email}"     Width="190"/>
                            <DataGridTextColumn Header="Статус"         Binding="{Binding Status}"    Width="110"/>
                            <DataGridTextColumn Header="Последний вход" Binding="{Binding LastLogin}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ═══ ПРЕПОДАВАТЕЛИ ═══ -->
            <TabItem Style="{StaticResource NavItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🎓" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Преподаватели" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="White"
                            BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Преподаватели" FontSize="15"
                                           FontWeight="SemiBold" Foreground="#1F1F1F"/>
                                <TextBlock Text="Штатный состав преподавателей колледжа"
                                           FontSize="11" Foreground="#A19F9D" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock x:Name="TxtTeachersTotal" Grid.Column="1"
                                       FontSize="11" Foreground="#605E5C"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Background="#FAFAFA"
                            BorderBrush="#EFEFEF" BorderThickness="0,0,0,1" Padding="20,8">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+ Добавить преподавателя"
                                    Style="{StaticResource PrimaryBtn}"
                                    Margin="0,0,8,0" Click="BtnAddTeacher_Click"/>
                            <Button Content="✎  Редактировать"
                                    Style="{StaticResource SecondaryBtn}"
                                    Margin="0,0,8,0" Click="BtnEditTeacher_Click"/>
                            <Button Content="✕  Удалить"
                                    Style="{StaticResource DangerBtn}"
                                    Click="BtnDeleteTeacher_Click"/>
                        </StackPanel>
                    </Border>

                    <DataGrid x:Name="TeachersAdminGrid" Grid.Row="2"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F0F0F0"
                              BorderThickness="0" Background="White" RowBackground="White"
                              AlternatingRowBackground="#FDFDFD" HeadersVisibility="Column"
                              SelectionMode="Single" CanUserResizeRows="False"
                              FontFamily="Segoe UI" FontSize="12" RowHeight="38"
                              ColumnHeaderStyle="{StaticResource GridHeader}"
                              CellStyle="{StaticResource GridCell}"
                              RowStyle="{StaticResource GridRow}"
                              MouseDoubleClick="TeachersAdminGrid_DoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ФИО"        Binding="{Binding FullName}"   Width="*"/>
                            <DataGridTextColumn Header="Дисциплин"  Binding="{Binding SubjectCount}" Width="100"/>
                            <DataGridTextColumn Header="Статус"     Binding="{Binding StatusText}"   Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ═══ ДИСЦИПЛИНЫ ═══ -->
            <TabItem Style="{StaticResource NavItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📖" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Дисциплины" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="White"
                            BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Учебные дисциплины" FontSize="15"
                                           FontWeight="SemiBold" Foreground="#1F1F1F"/>
                                <TextBlock Text="Справочник предметов, привязка к группам и преподавателям"
                                           FontSize="11" Foreground="#A19F9D" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock x:Name="TxtSubjectsTotal" Grid.Column="1"
                                       FontSize="11" Foreground="#605E5C"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Background="#FAFAFA"
                            BorderBrush="#EFEFEF" BorderThickness="0,0,0,1" Padding="20,8">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+ Добавить дисциплину"
                                    Style="{StaticResource PrimaryBtn}"
                                    Margin="0,0,8,0" Click="BtnAddSubject_Click"/>
                            <Button Content="✎  Редактировать"
                                    Style="{StaticResource SecondaryBtn}"
                                    Margin="0,0,8,0" Click="BtnEditSubject_Click"/>
                            <Button Content="✕  Удалить"
                                    Style="{StaticResource DangerBtn}"
                                    Click="BtnDeleteSubject_Click"/>
                        </StackPanel>
                    </Border>

                    <DataGrid x:Name="SubjectsAdminGrid" Grid.Row="2"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F0F0F0"
                              BorderThickness="0" Background="White" RowBackground="White"
                              AlternatingRowBackground="#FDFDFD" HeadersVisibility="Column"
                              SelectionMode="Single" CanUserResizeRows="False"
                              FontFamily="Segoe UI" FontSize="12" RowHeight="38"
                              ColumnHeaderStyle="{StaticResource GridHeader}"
                              CellStyle="{StaticResource GridCell}"
                              RowStyle="{StaticResource GridRow}"
                              MouseDoubleClick="SubjectsAdminGrid_DoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дисциплина"    Binding="{Binding SubjectName}" Width="*"/>
                            <DataGridTextColumn Header="Группа"        Binding="{Binding GroupName}"   Width="90"/>
                            <DataGridTextColumn Header="Преподаватель" Binding="{Binding TeacherName}" Width="180"/>
                            <DataGridTextColumn Header="Часов"         Binding="{Binding HoursTotal}"  Width="65"/>
                            <DataGridTextColumn Header="Семестр"       Binding="{Binding Semester}"    Width="70"/>
                            <DataGridTextColumn Header="Контроль"      Binding="{Binding ControlType}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ═══ УЧЕБНЫЕ ГОДЫ ═══ -->
            <TabItem Style="{StaticResource NavItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📅" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Учебные годы" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="White"
                            BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Учебные годы" FontSize="15"
                                           FontWeight="SemiBold" Foreground="#1F1F1F"/>
                                <TextBlock Text="Академические периоды и текущий учебный год"
                                           FontSize="11" Foreground="#A19F9D" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock x:Name="TxtYearsTotal" Grid.Column="1"
                                       FontSize="11" Foreground="#605E5C"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Background="#FAFAFA"
                            BorderBrush="#EFEFEF" BorderThickness="0,0,0,1" Padding="20,8">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+ Добавить год"
                                    Style="{StaticResource PrimaryBtn}"
                                    Margin="0,0,8,0" Click="BtnAddYear_Click"/>
                            <Button Content="✎  Редактировать"
                                    Style="{StaticResource SecondaryBtn}"
                                    Margin="0,0,8,0" Click="BtnEditYear_Click"/>
                            <Button Content="✕  Удалить"
                                    Style="{StaticResource DangerBtn}"
                                    Click="BtnDeleteYear_Click"/>
                        </StackPanel>
                    </Border>

                    <DataGrid x:Name="YearsAdminGrid" Grid.Row="2"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F0F0F0"
                              BorderThickness="0" Background="White" RowBackground="White"
                              AlternatingRowBackground="#FDFDFD" HeadersVisibility="Column"
                              SelectionMode="Single" CanUserResizeRows="False"
                              FontFamily="Segoe UI" FontSize="12" RowHeight="38"
                              ColumnHeaderStyle="{StaticResource GridHeader}"
                              CellStyle="{StaticResource GridCell}"
                              RowStyle="{StaticResource GridRow}"
                              MouseDoubleClick="YearsAdminGrid_DoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Учебный год" Binding="{Binding Title}"      Width="160"/>
                            <DataGridTextColumn Header="Дата начала" Binding="{Binding StartDate}"  Width="120"/>
                            <DataGridTextColumn Header="Дата конца"  Binding="{Binding EndDate}"    Width="120"/>
                            <DataGridTextColumn Header="Статус"      Binding="{Binding StatusText}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ═══ ОБЩЕЖИТИЯ ═══ -->
            <TabItem Style="{StaticResource NavItem}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🏠" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Общежития" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="White"
                            BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Общежития" FontSize="15"
                                           FontWeight="SemiBold" Foreground="#1F1F1F"/>
                                <TextBlock Text="База студенческих общежитий и комендантов"
                                           FontSize="11" Foreground="#A19F9D" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock x:Name="TxtDormsTotal" Grid.Column="1"
                                       FontSize="11" Foreground="#605E5C"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Background="#FAFAFA"
                            BorderBrush="#EFEFEF" BorderThickness="0,0,0,1" Padding="20,8">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+ Добавить общежитие"
                                    Style="{StaticResource PrimaryBtn}"
                                    Margin="0,0,8,0" Click="BtnAddDorm_Click"/>
                            <Button Content="✎  Редактировать"
                                    Style="{StaticResource SecondaryBtn}"
                                    Margin="0,0,8,0" Click="BtnEditDorm_Click"/>
                            <Button Content="✕  Удалить"
                                    Style="{StaticResource DangerBtn}"
                                    Click="BtnDeleteDorm_Click"/>
                        </StackPanel>
                    </Border>

                    <DataGrid x:Name="DormsAdminGrid" Grid.Row="2"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F0F0F0"
                              BorderThickness="0" Background="White" RowBackground="White"
                              AlternatingRowBackground="#FDFDFD" HeadersVisibility="Column"
                              SelectionMode="Single" CanUserResizeRows="False"
                              FontFamily="Segoe UI" FontSize="12" RowHeight="38"
                              ColumnHeaderStyle="{StaticResource GridHeader}"
                              CellStyle="{StaticResource GridCell}"
                              RowStyle="{StaticResource GridRow}"
                              MouseDoubleClick="DormsAdminGrid_DoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Название"  Binding="{Binding Name}"       Width="180"/>
                            <DataGridTextColumn Header="Адрес"     Binding="{Binding Address}"    Width="*"/>
                            <DataGridTextColumn Header="Комендант" Binding="{Binding Commandant}" Width="180"/>
                            <DataGridTextColumn Header="Телефон"   Binding="{Binding Phone}"      Width="130"/>
                            <DataGridTextColumn Header="Комнат"    Binding="{Binding TotalRooms}" Width="75"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Page>
