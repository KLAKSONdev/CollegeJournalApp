<Page x:Class="CollegeJournalApp.Views.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#FAF9F8"
      FontFamily="Segoe UI"
      Title="Управление">

    <Page.Resources>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
        </Style>
        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#323130"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#D13438"/>
            <Setter Property="BorderBrush" Value="#D13438"/>
        </Style>
        <Style x:Key="GridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F3F2F1"/>
            <Setter Property="Foreground" Value="#605E5C"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style x:Key="GridCell" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1" Padding="24,14">
            <TextBlock Text="Управление данными" FontSize="18"
                       FontWeight="SemiBold" Foreground="#1F1F1F"/>
        </Border>

        <!-- Вкладки управления -->
        <TabControl Grid.Row="1" Background="#FAF9F8"
                    BorderBrush="#E0E0E0" BorderThickness="0,0,0,0"
                    Margin="16,12,16,16">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="FontFamily" Value="Segoe UI"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Padding" Value="16,8"/>
                    <Setter Property="Foreground" Value="#605E5C"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="#0078D4"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <!-- ═══ СТУДЕНТЫ ═══ -->
            <TabItem Header="Студенты" x:Name="TabStudents">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Тулбар -->
                    <Border Grid.Row="0" Background="White" Padding="12,8"
                            BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+ Добавить студента"
                                    Style="{StaticResource PrimaryBtn}"
                                    Margin="0,0,8,0" Click="BtnAddStudent_Click"/>
                            <Button Content="✎ Редактировать"
                                    Style="{StaticResource SecondaryBtn}"
                                    Margin="0,0,8,0" Click="BtnEditStudent_Click"/>
                            <Button Content="✕ Удалить"
                                    Style="{StaticResource DangerBtn}"
                                    Click="BtnDeleteStudent_Click"/>
                            <Border Width="1" Background="#E0E0E0" Margin="12,0"/>
                            <Border BorderBrush="#D0D0D0" BorderThickness="1" Width="200" Height="30">
                                <TextBox x:Name="TxtStudentSearch" BorderThickness="0"
                                         Padding="8,6" FontSize="12" Background="White"
                                         TextChanged="TxtStudentSearch_Changed">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                                <VisualBrush.Visual>
                                                                    <TextBlock Text="Поиск..." Foreground="#A19F9D"
                                                                               FontFamily="Segoe UI" FontSize="12" Margin="8,6,0,0"/>
                                                                </VisualBrush.Visual>
                                                            </VisualBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </Border>
                            <TextBlock x:Name="TxtStudentsTotal" Foreground="#605E5C"
                                       FontSize="11" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Таблица студентов -->
                    <DataGrid x:Name="StudentsAdminGrid" Grid.Row="1"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F3F2F1"
                              BorderThickness="0"
                              Background="White" RowBackground="White"
                              AlternatingRowBackground="#FAFAFA"
                              HeadersVisibility="Column" SelectionMode="Single"
                              CanUserResizeRows="False" FontFamily="Segoe UI"
                              FontSize="12" RowHeight="36"
                              ColumnHeaderStyle="{StaticResource GridHeader}"
                              CellStyle="{StaticResource GridCell}"
                              MouseDoubleClick="StudentsAdminGrid_DoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ФИО"         Binding="{Binding FullName}"    Width="220"/>
                            <DataGridTextColumn Header="Группа"      Binding="{Binding GroupName}"   Width="100"/>
                            <DataGridTextColumn Header="Зач. книжка" Binding="{Binding StudentCode}" Width="100"/>
                            <DataGridTextColumn Header="Дата рожд."  Binding="{Binding BirthDate}"   Width="100"/>
                            <DataGridTextColumn Header="Пол"         Binding="{Binding Gender}"      Width="70"/>
                            <DataGridTextColumn Header="Основание"   Binding="{Binding StudyBasis}"  Width="90"/>
                            <DataGridTextColumn Header="Общежитие"   Binding="{Binding Dormitory}"   Width="120"/>
                            <DataGridTextColumn Header="Телефон"     Binding="{Binding Phone}"       Width="120"/>
                            <DataGridTextColumn Header="Статус"      Binding="{Binding Status}"      Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ═══ ГРУППЫ ═══ -->
            <TabItem Header="Группы">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="White" Padding="12,8"
                            BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+ Добавить группу"
                                    Style="{StaticResource PrimaryBtn}"
                                    Margin="0,0,8,0" Click="BtnAddGroup_Click"/>
                            <Button Content="✎ Редактировать"
                                    Style="{StaticResource SecondaryBtn}"
                                    Margin="0,0,8,0" Click="BtnEditGroup_Click"/>
                            <Button Content="✕ Удалить"
                                    Style="{StaticResource DangerBtn}"
                                    Click="BtnDeleteGroup_Click"/>
                            <TextBlock x:Name="TxtGroupsTotal" Foreground="#605E5C"
                                       FontSize="11" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <DataGrid x:Name="GroupsAdminGrid" Grid.Row="1"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F3F2F1"
                              BorderThickness="0"
                              Background="White" RowBackground="White"
                              AlternatingRowBackground="#FAFAFA"
                              HeadersVisibility="Column" SelectionMode="Single"
                              CanUserResizeRows="False" FontFamily="Segoe UI"
                              FontSize="12" RowHeight="36"
                              ColumnHeaderStyle="{StaticResource GridHeader}"
                              CellStyle="{StaticResource GridCell}"
                              MouseDoubleClick="GroupsAdminGrid_DoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Группа"      Binding="{Binding GroupName}"     Width="100"/>
                            <DataGridTextColumn Header="Специальность" Binding="{Binding Specialty}"   Width="*"/>
                            <DataGridTextColumn Header="Код"         Binding="{Binding SpecialtyCode}" Width="90"/>
                            <DataGridTextColumn Header="Курс"        Binding="{Binding Course}"        Width="60"/>
                            <DataGridTextColumn Header="Семестр"     Binding="{Binding Semester}"      Width="70"/>
                            <DataGridTextColumn Header="Форма"       Binding="{Binding EduForm}"       Width="90"/>
                            <DataGridTextColumn Header="Основание"   Binding="{Binding EduBasis}"      Width="90"/>
                            <DataGridTextColumn Header="Куратор"     Binding="{Binding CuratorName}"   Width="160"/>
                            <DataGridTextColumn Header="Студентов"   Binding="{Binding StudentCount}"  Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ═══ ПОЛЬЗОВАТЕЛИ ═══ -->
            <TabItem Header="Пользователи">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="White" Padding="12,8"
                            BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+ Добавить пользователя"
                                    Style="{StaticResource PrimaryBtn}"
                                    Margin="0,0,8,0" Click="BtnAddUser_Click"/>
                            <Button Content="✎ Редактировать"
                                    Style="{StaticResource SecondaryBtn}"
                                    Margin="0,0,8,0" Click="BtnEditUser_Click"/>
                            <Button Content="⊘ Заблокировать / Разблокировать"
                                    Style="{StaticResource DangerBtn}"
                                    Click="BtnToggleUser_Click"/>
                            <TextBlock x:Name="TxtUsersTotal" Foreground="#605E5C"
                                       FontSize="11" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <DataGrid x:Name="UsersAdminGrid" Grid.Row="1"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F3F2F1"
                              BorderThickness="0"
                              Background="White" RowBackground="White"
                              AlternatingRowBackground="#FAFAFA"
                              HeadersVisibility="Column" SelectionMode="Single"
                              CanUserResizeRows="False" FontFamily="Segoe UI"
                              FontSize="12" RowHeight="36"
                              ColumnHeaderStyle="{StaticResource GridHeader}"
                              CellStyle="{StaticResource GridCell}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Логин"    Binding="{Binding Login}"    Width="130"/>
                            <DataGridTextColumn Header="ФИО"      Binding="{Binding FullName}" Width="220"/>
                            <DataGridTextColumn Header="Роль"     Binding="{Binding Role}"     Width="110"/>
                            <DataGridTextColumn Header="Телефон"  Binding="{Binding Phone}"    Width="130"/>
                            <DataGridTextColumn Header="Email"    Binding="{Binding Email}"    Width="180"/>
                            <DataGridTextColumn Header="Статус"   Binding="{Binding Status}"   Width="100"/>
                            <DataGridTextColumn Header="Последний вход" Binding="{Binding LastLogin}" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Page>
