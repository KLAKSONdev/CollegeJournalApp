<Page x:Class="CollegeJournalApp.Views.Pages.AttendancePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#EDF2F7" FontFamily="Segoe UI" Title="Посещаемость">


    <Page.Resources>

        <Style x:Key="ColHdr" TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#F8F9FA"/>
            <Setter Property="Foreground"      Value="#495057"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="14,10"/>
            <Setter Property="BorderBrush"     Value="#DEE2E6"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style x:Key="Cell" TargetType="DataGridCell">
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Padding"           Value="14,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E8F4FD"/>
                    <Setter Property="Foreground" Value="#1A1A2E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActBtn" TargetType="Button">
            <Setter Property="Width"           Value="28"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="14"/>
        </Style>

        <!-- Универсальный стиль для скруглённых кнопок -->
        <Style x:Key="RoundBtn" TargetType="Button">
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для кнопки с рамкой -->
        <Style x:Key="RoundOutlineBtn" TargetType="Button" BasedOn="{StaticResource RoundBtn}">
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════ ШАПКА ══════════════════ -->
        <Border Grid.Row="0" Background="White">
            <Border.Effect>
                <DropShadowEffect Color="#1A2B4A" Opacity="0.07"
                                  BlurRadius="10" ShadowDepth="2" Direction="270"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- Синяя полоска слева -->
                <Border Grid.Column="0" Background="#0078D4"/>
                <!-- Контент шапки -->
                <Grid Grid.Column="1" Margin="22,15,22,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Посещаемость" FontSize="20" FontWeight="Bold" Foreground="#1A1A2E"/>
                        <TextBlock x:Name="TxtTotal" Text="" FontSize="12" Foreground="#6C757D"
                                   VerticalAlignment="Bottom" Margin="12,0,0,2"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BtnToggleCharts"
                                Content="📊  Графики"
                                Height="36" Padding="14,0" Margin="0,0,8,0"
                                Background="White" BorderBrush="#CED4DA" Foreground="#495057"
                                FontSize="12" FontWeight="SemiBold"
                                Style="{StaticResource RoundOutlineBtn}"
                                Click="BtnToggleCharts_Click"/>
                        <Button x:Name="BtnMarkAttendance"
                                Content="＋  Отметить посещаемость"
                                Height="36" Padding="18,0"
                                Background="#0078D4" Foreground="White"
                                FontSize="12" FontWeight="SemiBold"
                                Visibility="Collapsed"
                                Style="{StaticResource RoundBtn}"
                                Click="BtnMarkAttendance_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ══════════════════ КАРТОЧКИ ══════════════════ -->
        <UniformGrid Grid.Row="1" Columns="5" Margin="16,14,16,0">

            <!-- Присутствовал -->
            <Border x:Name="CardPresent" Margin="0,0,8,0"
                    Background="White" BorderThickness="0" CornerRadius="10"
                    Cursor="Hand" MouseLeftButtonUp="CardPresent_Click">
                <Border.Effect>
                    <DropShadowEffect Color="#1A2B4A" Opacity="0.1" BlurRadius="10" ShadowDepth="3" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#107C10" CornerRadius="10 0 0 10"/>
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="5"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="14,12,14,10">
                            <TextBlock x:Name="StatPresent" Text="—" FontSize="28"
                                       FontWeight="Bold" Foreground="#107C10"/>
                            <TextBlock Text="Присутствовал" FontSize="10"
                                       Foreground="#6C757D" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Grid Grid.Row="1" x:Name="BarPresent" Background="#DEE2E6">
                            <Border x:Name="BarPresentFill" HorizontalAlignment="Left"
                                    Background="#107C10" Width="0"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- Отсутствовал -->
            <Border x:Name="CardAbsent" Margin="0,0,8,0"
                    Background="White" BorderThickness="0" CornerRadius="10"
                    Cursor="Hand" MouseLeftButtonUp="CardAbsent_Click">
                <Border.Effect>
                    <DropShadowEffect Color="#1A2B4A" Opacity="0.1" BlurRadius="10" ShadowDepth="3" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#D13438" CornerRadius="10 0 0 10"/>
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="5"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="14,12,14,10">
                            <TextBlock x:Name="StatAbsent" Text="—" FontSize="28"
                                       FontWeight="Bold" Foreground="#D13438"/>
                            <TextBlock Text="Отсутствовал" FontSize="10"
                                       Foreground="#6C757D" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Grid Grid.Row="1" x:Name="BarAbsent" Background="#DEE2E6">
                            <Border x:Name="BarAbsentFill" HorizontalAlignment="Left"
                                    Background="#D13438" Width="0"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- Опоздал -->
            <Border x:Name="CardLate" Margin="0,0,8,0"
                    Background="White" BorderThickness="0" CornerRadius="10"
                    Cursor="Hand" MouseLeftButtonUp="CardLate_Click">
                <Border.Effect>
                    <DropShadowEffect Color="#1A2B4A" Opacity="0.1" BlurRadius="10" ShadowDepth="3" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#CA5010" CornerRadius="10 0 0 10"/>
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="5"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="14,12,14,10">
                            <TextBlock x:Name="StatLate" Text="—" FontSize="28"
                                       FontWeight="Bold" Foreground="#CA5010"/>
                            <TextBlock Text="Опоздал" FontSize="10"
                                       Foreground="#6C757D" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Grid Grid.Row="1" x:Name="BarLate" Background="#DEE2E6">
                            <Border x:Name="BarLateFill" HorizontalAlignment="Left"
                                    Background="#CA5010" Width="0"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- Уважительная причина -->
            <Border x:Name="CardExcused" Margin="0,0,8,0"
                    Background="White" BorderThickness="0" CornerRadius="10"
                    Cursor="Hand" MouseLeftButtonUp="CardExcused_Click">
                <Border.Effect>
                    <DropShadowEffect Color="#1A2B4A" Opacity="0.1" BlurRadius="10" ShadowDepth="3" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#0078D4" CornerRadius="10 0 0 10"/>
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="5"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="14,12,14,10">
                            <TextBlock x:Name="StatExcused" Text="—" FontSize="28"
                                       FontWeight="Bold" Foreground="#0078D4"/>
                            <TextBlock Text="Уважит. причина" FontSize="10"
                                       Foreground="#6C757D" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Grid Grid.Row="1" x:Name="BarExcused" Background="#DEE2E6">
                            <Border x:Name="BarExcusedFill" HorizontalAlignment="Left"
                                    Background="#0078D4" Width="0"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- % Посещаемости (не кликабельна) -->
            <Border Background="White" BorderThickness="0" CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect Color="#1A2B4A" Opacity="0.1" BlurRadius="10" ShadowDepth="3" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#6B69D6" CornerRadius="10 0 0 10"/>
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="5"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="14,12,14,10">
                            <TextBlock x:Name="StatPercent" Text="—" FontSize="28"
                                       FontWeight="Bold" Foreground="#6B69D6"/>
                            <TextBlock Text="Посещаемость" FontSize="10"
                                       Foreground="#6C757D" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Grid Grid.Row="1" x:Name="BarPercent" Background="#DEE2E6">
                            <Border x:Name="BarPercentFill" HorizontalAlignment="Left"
                                    Background="#6B69D6" Width="0"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

        </UniformGrid>

        <!-- ══════════════════ ГРАФИКИ ══════════════════ -->
        <Border x:Name="PanelCharts" Grid.Row="2" Margin="16,10,16,0"
                Background="White" BorderThickness="0" CornerRadius="10"
                Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect Color="#1A2B4A" Opacity="0.08"
                                  BlurRadius="10" ShadowDepth="2" Direction="270"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Круговая диаграмма -->
                <Grid Grid.Column="0" Margin="18,14,18,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Распределение статусов"
                               FontSize="12" FontWeight="SemiBold" Foreground="#495057"
                               Margin="0,0,0,10"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Canvas x:Name="PieCanvas" Grid.Column="0" Height="150"/>
                        <StackPanel x:Name="PieLegend" Grid.Column="1"
                                    VerticalAlignment="Center" Margin="14,0,0,0" Width="148"/>
                    </Grid>
                </Grid>

                <!-- Разделитель -->
                <Border Grid.Column="1" Width="1" Background="#E9ECEF" Margin="0,10,0,10"/>

                <!-- Столбчатая диаграмма -->
                <Grid Grid.Column="2" Margin="18,14,18,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Посещаемость по датам"
                               FontSize="12" FontWeight="SemiBold" Foreground="#495057"
                               Margin="0,0,0,10"/>
                    <Canvas x:Name="BarCanvas" Grid.Row="1" Height="160"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ══════════════════ ФИЛЬТРЫ ══════════════════ -->
        <Border x:Name="PanelFilters" Grid.Row="3"
                Background="White" BorderThickness="0" CornerRadius="10"
                Margin="16,12,16,0" Padding="16,10">
            <Border.Effect>
                <DropShadowEffect Color="#1A2B4A" Opacity="0.08"
                                  BlurRadius="10" ShadowDepth="2" Direction="270"/>
            </Border.Effect>
            <WrapPanel>
                <!-- Поиск -->
                <Border BorderBrush="#CED4DA" BorderThickness="1" CornerRadius="6"
                        Width="190" Height="30" Margin="0,0,6,4">
                    <TextBox x:Name="TxtSearch" BorderThickness="0" Padding="10,6"
                             FontSize="12" Background="Transparent"
                             TextChanged="Filter_Changed">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="🔍  Поиск по студенту..."
                                                                   Foreground="#ADB5BD"
                                                                   FontFamily="Segoe UI"
                                                                   FontSize="11" Margin="10,6,0,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Border>
                <DatePicker x:Name="DtFrom" Width="128" Height="30" Margin="0,0,4,4"
                            FontSize="11" SelectedDateChanged="Filter_Changed" ToolTip="Дата с"/>
                <DatePicker x:Name="DtTo"   Width="128" Height="30" Margin="0,0,6,4"
                            FontSize="11" SelectedDateChanged="Filter_Changed" ToolTip="Дата по"/>
                <!-- CmbStatus скрыт — фильтр через карточки -->
                <ComboBox x:Name="CmbStatus" Width="150" Height="30" Margin="0,0,6,4"
                          FontSize="12" Visibility="Collapsed" SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="Все статусы" IsSelected="True"/>
                    <ComboBoxItem Content="Присутствовал"/>
                    <ComboBoxItem Content="Отсутствовал"/>
                    <ComboBoxItem Content="Опоздал"/>
                    <ComboBoxItem Content="Уважительная причина"/>
                </ComboBox>
                <ComboBox x:Name="CmbSubject" Width="180" Height="30" Margin="0,0,6,4"
                          FontSize="12" SelectionChanged="Filter_Changed"/>
                <ComboBox x:Name="CmbGroup"   Width="120" Height="30" Margin="0,0,6,4"
                          FontSize="12" Visibility="Collapsed" SelectionChanged="Filter_Changed"/>
                <Button Content="Сбросить" Height="30" Padding="14,0" Margin="0,0,6,4"
                        Background="White" BorderBrush="#CED4DA" Foreground="#6C757D"
                        FontSize="12"
                        Style="{StaticResource RoundOutlineBtn}"
                        Click="BtnReset_Click"/>
                <Button Content="📥  Экспорт" Height="30" Padding="14,0" Margin="0,0,0,4"
                        Background="#198754" Foreground="White"
                        FontSize="12"
                        Style="{StaticResource RoundBtn}"
                        Click="BtnExport_Click"/>
            </WrapPanel>
        </Border>

        <!-- ══════════════════ ТАБЛИЦА ══════════════════ -->
        <Border x:Name="PanelGrid" Grid.Row="4" Margin="16,10,16,16"
                Background="White" BorderThickness="0" CornerRadius="10">
            <Border.Effect>
                <DropShadowEffect Color="#1A2B4A" Opacity="0.1"
                                  BlurRadius="14" ShadowDepth="3" Direction="270"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ── Панель групповых действий (под таблицей, чтоб строки не сдвигались) ── -->
                <Border x:Name="BulkPanel" Grid.Row="1"
                        Background="#EBF5FB" BorderBrush="#BDD9EF"
                        BorderThickness="0,0,0,1" Padding="14,8"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Счётчик -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="0,0,16,0">
                            <Border Background="#0078D4" CornerRadius="10"
                                    Padding="8,2" Margin="0,0,8,0">
                                <TextBlock x:Name="TxtSelectedCount" FontSize="11"
                                           FontWeight="Bold" Foreground="White"/>
                            </Border>
                            <TextBlock Text="выбрано" FontSize="12"
                                       Foreground="#0056A0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Метка -->
                        <TextBlock Grid.Column="1" Text="→  новый статус:"
                                   FontSize="12" Foreground="#495057"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>

                        <!-- Выбор статуса -->
                        <ComboBox x:Name="CmbBulkStatus" Grid.Column="2"
                                  Width="190" Height="28" FontSize="12">
                            <ComboBoxItem Content="Присутствовал"/>
                            <ComboBoxItem Content="Отсутствовал"/>
                            <ComboBoxItem Content="Опоздал"/>
                            <ComboBoxItem Content="Уважительная причина" IsSelected="True"/>
                        </ComboBox>

                        <!-- Причина с плейсхолдером -->
                        <Grid Grid.Column="3" Margin="8,0" Width="210" Height="28">
                            <Border BorderBrush="#BDD9EF" BorderThickness="1"
                                    CornerRadius="5" Background="White">
                                <TextBox x:Name="TxtBulkReason" BorderThickness="0"
                                         Padding="8,4" FontSize="12" Background="Transparent"
                                         VerticalContentAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Причина (необязательно)" FontSize="11"
                                       Foreground="#ADB5BD" IsHitTestVisible="False"
                                       Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=TxtBulkReason}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <!-- Применить -->
                        <Button x:Name="BtnApplyBulk" Grid.Column="4"
                                Content="✓  Применить"
                                Height="28" Padding="14,0" Margin="0,0,8,0"
                                HorizontalAlignment="Left"
                                Background="#0078D4" Foreground="White"
                                FontSize="12" FontWeight="SemiBold"
                                BorderThickness="0" Cursor="Hand"
                                Style="{StaticResource RoundBtn}"
                                Click="BtnApplyBulk_Click"/>

                        <!-- Снять выделение -->
                        <Button Grid.Column="5"
                                Content="✕  Снять"
                                Height="28" Padding="10,0"
                                Background="Transparent" Foreground="#495057"
                                FontSize="12" BorderBrush="#BDD9EF" BorderThickness="1"
                                Cursor="Hand"
                                Style="{StaticResource RoundOutlineBtn}"
                                Click="BtnClearBulk_Click"/>
                    </Grid>
                </Border>

                <DataGrid x:Name="AttGrid" Grid.Row="0"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F1F3F5"
                          BorderThickness="0" Background="White"
                          RowBackground="White" AlternatingRowBackground="#F8F9FA"
                          HeadersVisibility="Column" CanUserResizeRows="False"
                          CanUserSortColumns="True" SelectionMode="Extended"
                          FontFamily="Segoe UI" FontSize="12" RowHeight="38"
                          ColumnHeaderStyle="{StaticResource ColHdr}"
                          CellStyle="{StaticResource Cell}"
                          SelectionChanged="AttGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Дата"       Binding="{Binding LessonDate}"  Width="95"/>
                        <DataGridTextColumn Header="Студент"    Binding="{Binding StudentName}" Width="195"/>
                        <DataGridTextColumn x:Name="ColGroup"   Header="Группа"
                                            Binding="{Binding GroupName}" Width="95"/>
                        <DataGridTextColumn Header="Дисциплина" Binding="{Binding Subject}"     Width="*"/>
                        <DataGridTemplateColumn Header="Статус" Width="170" SortMemberPath="Status">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding StatusBg}" Padding="10,4"
                                            Margin="8,5" HorizontalAlignment="Left" CornerRadius="12">
                                        <TextBlock Text="{Binding Status}" FontSize="11"
                                                   Foreground="{Binding StatusFg}"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Причина" Binding="{Binding Reason}" Width="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#6C757D"/>
                                    <Setter Property="FontStyle"  Value="Italic"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn x:Name="ColActions" Header="" Width="64"
                                                Visibility="Collapsed">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Tag="{Binding AttendanceId}" Content="✏️"
                                                ToolTip="Редактировать"
                                                Style="{StaticResource ActBtn}"
                                                Click="BtnEdit_Click"/>
                                        <Button Tag="{Binding AttendanceId}" Content="🗑️"
                                                ToolTip="Удалить"
                                                Style="{StaticResource ActBtn}" Margin="2,0,0,0"
                                                Click="BtnDelete_Click"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Пагинация -->
                <Border Grid.Row="2" Background="#F8F9FA"
                        BorderBrush="#E9ECEF" BorderThickness="0,1,0,0"
                        Padding="16,8" CornerRadius="0 0 10 10">
                    <Grid>
                        <TextBlock x:Name="TxtPageInfo"
                                   HorizontalAlignment="Left" VerticalAlignment="Center"
                                   FontSize="11" Foreground="#6C757D"/>
                        <StackPanel x:Name="PaginationPanel"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="На странице:" FontSize="11" Foreground="#6C757D"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="CmbPageSize" Width="58" Height="25" FontSize="11"
                                      SelectionChanged="CmbPageSize_Changed">
                                <ComboBoxItem Content="15"/>
                                <ComboBoxItem Content="25" IsSelected="True"/>
                                <ComboBoxItem Content="50"/>
                                <ComboBoxItem Content="100"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════════════ ЛИЧНАЯ СТАТИСТИКА (Student) ══════════════════ -->
        <ScrollViewer x:Name="PanelStudent" Grid.Row="4"
                      Margin="16,10,16,16"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="Collapsed">
            <StackPanel>

                <!-- Карточка приветствия -->
                <Border Background="White" BorderThickness="0" CornerRadius="10"
                        Margin="0,0,0,10">
                    <Border.Effect>
                        <DropShadowEffect Color="#1A2B4A" Opacity="0.08" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#0078D4" CornerRadius="10 0 0 10"/>
                        <StackPanel Grid.Column="1" Margin="18,14,18,14">
                            <TextBlock x:Name="TxtStudentGreeting"
                                       FontSize="16" FontWeight="Bold" Foreground="#1A1A2E"/>
                            <TextBlock x:Name="TxtStudentGroup"
                                       FontSize="12" Foreground="#6C757D" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Карточка по дисциплинам -->
                <Border Background="White" BorderThickness="0" CornerRadius="10"
                        Padding="20,16" Margin="0,0,0,10">
                    <Border.Effect>
                        <DropShadowEffect Color="#1A2B4A" Opacity="0.08" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="По дисциплинам" FontSize="13"
                                   FontWeight="SemiBold" Foreground="#1A1A2E" Margin="0,0,0,14"/>
                        <StackPanel x:Name="SubjectBars"/>
                    </StackPanel>
                </Border>

                <!-- История посещений -->
                <Border Background="White" BorderThickness="0" CornerRadius="10" Margin="0,0,0,4">
                    <Border.Effect>
                        <DropShadowEffect Color="#1A2B4A" Opacity="0.08" BlurRadius="10" ShadowDepth="2" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <Border BorderBrush="#E9ECEF" BorderThickness="0,0,0,1" Padding="20,13">
                            <TextBlock Text="История посещений" FontSize="13"
                                       FontWeight="SemiBold" Foreground="#1A1A2E"/>
                        </Border>
                        <DataGrid x:Name="StudentGrid"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#F1F3F5"
                                  BorderThickness="0" Background="White"
                                  RowBackground="White" AlternatingRowBackground="#F8F9FA"
                                  HeadersVisibility="Column" CanUserResizeRows="False"
                                  MaxHeight="380" FontFamily="Segoe UI" FontSize="12" RowHeight="36"
                                  ColumnHeaderStyle="{StaticResource ColHdr}"
                                  CellStyle="{StaticResource Cell}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Дата"       Binding="{Binding LessonDate}" Width="95"/>
                                <DataGridTextColumn Header="Дисциплина" Binding="{Binding Subject}"    Width="*"/>
                                <DataGridTemplateColumn Header="Статус" Width="170">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding StatusBg}" Padding="10,4"
                                                    Margin="8,4" HorizontalAlignment="Left" CornerRadius="12">
                                                <TextBlock Text="{Binding Status}" FontSize="11"
                                                           Foreground="{Binding StatusFg}"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Причина" Binding="{Binding Reason}" Width="160">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#6C757D"/>
                                            <Setter Property="FontStyle"  Value="Italic"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
