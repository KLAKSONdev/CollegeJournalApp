<Window x:Class="CollegeJournalApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Классный журнал"
        Height="700" Width="1200"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#FFFFFF"
        FontFamily="Segoe UI"
        WindowStyle="None"
        ResizeMode="CanResize"
        Loaded="Window_Loaded"
        PreviewKeyDown="Window_PreviewKeyDown">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="49"
                      ResizeBorderThickness="5"
                      CornerRadius="0"
                      GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TabStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#323130"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0,0,0,3"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F3F3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabActiveStyle" TargetType="Button" BasedOn="{StaticResource TabStyle}">
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent"
                                BorderThickness="0,0,0,3"
                                BorderBrush="#0078D4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль кнопок управления окном -->
        <Style x:Key="WinBtnStyle" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Width"            Value="42"/>
            <Setter Property="Height"           Value="49"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка закрытия — красный hover -->
        <Style x:Key="WinCloseBtnStyle" TargetType="Button" BasedOn="{StaticResource WinBtnStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C50F1F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="49"/>
            <RowDefinition Height="31"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- СТРОКА ЗАГОЛОВКА -->
        <Border Grid.Row="0" Background="#0078D4">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="35" Height="35" Margin="0,0,8,0">
                        <Image Source="C:\Users\Клаксон\source\repos\CollegeJournalApp\CollegeJournalApp\Img\Icon3.png" Margin="-12,-8,-16,-12"/>
                    </Border>
                    <TextBlock Text="EduTrack Pro"
                               Foreground="White" FontSize="50" FontFamily="Arial Black"
                               VerticalAlignment="Center" FontWeight="Bold" Width="371" Height="48" TextAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Группа: " Foreground="#C8E6FF" FontSize="12"/>
                    <TextBlock x:Name="TxtGroupName" Text="—"
                               Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#005A9E" Padding="8,2" Margin="0,0,8,0"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True" Width="91" Height="39">
                        <TextBlock x:Name="TxtRole" Foreground="White" FontSize="10" Margin="-5,8,-5,8" TextAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="TxtUserName" Foreground="White" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>

                    <!-- Колокольчик уведомлений -->
                    <Grid Margin="0,0,10,0" VerticalAlignment="Center" Width="26" Height="26"
                          shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button x:Name="BtnNotifications" Width="26" Height="26"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" ToolTip="Уведомления"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                Click="BtnNotifications_Click">
                            <TextBlock Text="🔔" FontSize="13"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Border x:Name="NotifBadge" Background="#E81123" CornerRadius="6"
                                MinWidth="14" Height="14"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,0,-4,0" Padding="3,0"
                                Visibility="Collapsed">
                            <TextBlock x:Name="NotifBadgeText" Text="0"
                                       FontSize="8" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <Button x:Name="BtnLogout" Content="Выйти"
                            Foreground="White" Background="Transparent"
                            BorderBrush="#80FFFFFF" BorderThickness="1"
                            FontFamily="Segoe UI" FontSize="11"
                            Padding="10,3" Cursor="Hand"
                            Margin="0,0,12,0"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="BtnLogout_Click" Height="44" Width="85"/>

                    <!-- Разделитель -->
                    <Rectangle Width="1" Height="20" Fill="#40FFFFFF" Margin="0,0,4,0"/>

                    <!-- Кнопки управления окном -->
                    <Button x:Name="BtnMinimize" Content="─"
                            Style="{StaticResource WinBtnStyle}"
                            Click="BtnMinimize_Click"/>
                    <Button x:Name="BtnMaximize" Content="□"
                            Style="{StaticResource WinBtnStyle}"
                            Click="BtnMaximize_Click"/>
                    <Button x:Name="BtnClose" Content="✕"
                            Style="{StaticResource WinCloseBtnStyle}"
                            Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- СТРОКА ВКЛАДОК — без ScrollViewer, все вкладки в одну строку -->
        <Border Grid.Row="1" Background="#FFFFFF"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <DockPanel Margin="4,0">
                <Button x:Name="TabDashboard"    Content="Главная"        Style="{StaticResource TabActiveStyle}" Tag="Dashboard"     Click="NavButton_Click"/>
                <Button x:Name="TabStudents"     Content="Студенты"       Style="{StaticResource TabStyle}"       Tag="Students"      Click="NavButton_Click"/>
                <Button x:Name="TabAttendance"   Content="Посещаемость"   Style="{StaticResource TabStyle}"       Tag="Attendance"    Click="NavButton_Click"/>
                <Button x:Name="TabGrades"       Content="Успеваемость"   Style="{StaticResource TabStyle}"       Tag="Grades"        Click="NavButton_Click"/>
                <Button x:Name="TabSchedule"     Content="Расписание"     Style="{StaticResource TabStyle}"       Tag="Schedule"      Click="NavButton_Click"/>
                <Button x:Name="TabEvents"       Content="События"        Style="{StaticResource TabStyle}"       Tag="Events"        Click="NavButton_Click"/>
                <Button x:Name="TabAnnouncements" Content="Объявления"     Style="{StaticResource TabStyle}"       Tag="Announcements" Click="NavButton_Click"/>
                <Button x:Name="TabAssignments"  Content="Поручения"      Style="{StaticResource TabStyle}"       Tag="Assignments"   Click="NavButton_Click"/>
                <Button x:Name="TabDocuments"    Content="Документы"      Style="{StaticResource TabStyle}"       Tag="Documents"     Click="NavButton_Click"/>
                <Button x:Name="TabSocial"       Content="Соц. карточки"  Style="{StaticResource TabStyle}"       Tag="Social"        Click="NavButton_Click"/>
                <Button x:Name="TabAchievements" Content="Достижения"     Style="{StaticResource TabStyle}"       Tag="Achievements"  Click="NavButton_Click"/>
                <Button x:Name="TabAudit"        Content="Журнал аудита"  Style="{StaticResource TabStyle}"       Tag="Audit"         Visibility="Collapsed" Click="NavButton_Click"/>
                <Button x:Name="TabUsers"        Content="Пользователи"   Style="{StaticResource TabStyle}"       Tag="Users"         Visibility="Collapsed" Click="NavButton_Click"/>
                <Button x:Name="TabAdmin"        Content="&#9881; Управление"  Style="{StaticResource TabStyle}"       Tag="Admin"         Visibility="Collapsed" Click="NavButton_Click"/>
            </DockPanel>
        </Border>

        <!-- КОНТЕНТ -->
        <Border Grid.Row="2" Background="#FAF9F8">
            <Frame x:Name="MainFrame"
                   NavigationUIVisibility="Hidden"
                   Background="Transparent"/>
        </Border>

        <!-- POPUP УВЕДОМЛЕНИЙ -->
        <Popup x:Name="NotifPopup"
               Grid.Row="0"
               PlacementTarget="{Binding ElementName=BtnNotifications}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <Border Background="White" CornerRadius="10" Width="370"
                    BorderBrush="#D8DCE0" BorderThickness="1"
                    Margin="0,6,0,0">
                <Border.Effect>
                    <DropShadowEffect Color="#1A2B4A" Opacity="0.18"
                                      BlurRadius="20" ShadowDepth="6" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок попапа -->
                    <Grid Grid.Row="0" Margin="16,12,12,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Уведомления" FontSize="13"
                                   FontWeight="SemiBold" Foreground="#1A1A2E"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="BtnMarkAllRead" Grid.Column="1"
                                Content="Прочитать все" FontSize="10"
                                Foreground="#0078D4" Background="Transparent"
                                BorderThickness="0" Cursor="Hand"
                                Click="BtnMarkAllRead_Click"/>
                    </Grid>
                    <Rectangle Grid.Row="0" Height="1" Fill="#EBEBEB" VerticalAlignment="Bottom"/>

                    <!-- Список объявлений -->
                    <ScrollViewer Grid.Row="1" MaxHeight="380"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="NotifList"/>
                    </ScrollViewer>

                    <!-- Подвал -->
                    <Border Grid.Row="2" BorderBrush="#EBEBEB" BorderThickness="0,1,0,0"
                            Padding="16,10">
                        <Button x:Name="BtnShowAllAnn"
                                Content="Открыть все объявления →"
                                Background="Transparent" BorderThickness="0"
                                FontSize="11" FontWeight="SemiBold"
                                Foreground="#0078D4" Cursor="Hand"
                                HorizontalAlignment="Left"
                                Click="BtnShowAllAnn_Click"/>
                    </Border>
                </Grid>
            </Border>
        </Popup>

    </Grid>
</Window>
