<Window x:Class="CollegeJournalApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Классный журнал"
        Height="700" Width="1200"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#FFFFFF"
        FontFamily="Segoe UI"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="TabStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#323130"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0,0,0,3"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F3F3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabActiveStyle" TargetType="Button" BasedOn="{StaticResource TabStyle}">
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent"
                                BorderThickness="0,0,0,3"
                                BorderBrush="#0078D4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- СТРОКА ЗАГОЛОВКА -->
        <Border Grid.Row="0" Background="#0078D4">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="20" Height="20" Background="White" Margin="0,0,8,0">
                        <TextBlock Text="КЖ" FontSize="9" FontWeight="Bold"
                                   Foreground="#0078D4" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Классный журнал"
                               Foreground="White" FontSize="12" FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Группа: " Foreground="#C8E6FF" FontSize="12"/>
                    <TextBlock x:Name="TxtGroupName" Text="—"
                               Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#005A9E" Padding="8,2" Margin="0,0,8,0">
                        <TextBlock x:Name="TxtRole" Foreground="White" FontSize="10"/>
                    </Border>
                    <TextBlock x:Name="TxtUserName" Foreground="White" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button x:Name="BtnLogout" Content="Выйти"
                            Foreground="White" Background="Transparent"
                            BorderBrush="#80FFFFFF" BorderThickness="1"
                            FontFamily="Segoe UI" FontSize="11"
                            Padding="10,3" Cursor="Hand"
                            Click="BtnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- СТРОКА ВКЛАДОК — без ScrollViewer, все вкладки в одну строку -->
        <Border Grid.Row="1" Background="#FFFFFF"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <DockPanel Margin="4,0">
                <Button x:Name="TabDashboard"    Content="Главная"        Style="{StaticResource TabActiveStyle}" Tag="Dashboard"     Click="NavButton_Click"/>
                <Button x:Name="TabStudents"     Content="Студенты"       Style="{StaticResource TabStyle}"       Tag="Students"      Click="NavButton_Click"/>
                <Button x:Name="TabAttendance"   Content="Посещаемость"   Style="{StaticResource TabStyle}"       Tag="Attendance"    Click="NavButton_Click"/>
                <Button x:Name="TabGrades"       Content="Успеваемость"   Style="{StaticResource TabStyle}"       Tag="Grades"        Click="NavButton_Click"/>
                <Button x:Name="TabSchedule"     Content="Расписание"     Style="{StaticResource TabStyle}"       Tag="Schedule"      Click="NavButton_Click"/>
                <Button x:Name="TabEvents"       Content="События"        Style="{StaticResource TabStyle}"       Tag="Events"        Click="NavButton_Click"/>
                <Button x:Name="TabAnnouncements" Content="Объявления"     Style="{StaticResource TabStyle}"       Tag="Announcements" Click="NavButton_Click"/>
                <Button x:Name="TabAssignments"  Content="Поручения"      Style="{StaticResource TabStyle}"       Tag="Assignments"   Click="NavButton_Click"/>
                <Button x:Name="TabDocuments"    Content="Документы"      Style="{StaticResource TabStyle}"       Tag="Documents"     Click="NavButton_Click"/>
                <Button x:Name="TabSocial"       Content="Соц. карточки"  Style="{StaticResource TabStyle}"       Tag="Social"        Click="NavButton_Click"/>
                <Button x:Name="TabAchievements" Content="Достижения"     Style="{StaticResource TabStyle}"       Tag="Achievements"  Click="NavButton_Click"/>
                <Button x:Name="TabAudit"        Content="Журнал аудита"  Style="{StaticResource TabStyle}"       Tag="Audit"         Visibility="Collapsed" Click="NavButton_Click"/>
                <Button x:Name="TabUsers"        Content="Пользователи"   Style="{StaticResource TabStyle}"       Tag="Users"         Visibility="Collapsed" Click="NavButton_Click"/>
            </DockPanel>
        </Border>

        <!-- КОНТЕНТ -->
        <Border Grid.Row="2" Background="#FAF9F8">
            <Frame x:Name="MainFrame"
                   NavigationUIVisibility="Hidden"
                   Background="Transparent"/>
        </Border>
    </Grid>
</Window>
